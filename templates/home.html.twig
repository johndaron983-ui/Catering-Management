                    <i class="fas fa-calendar-check mr-2"></i>Book Your Event
                </a>
                <a href="tel:+15551234567" class="btn-secondary border-white text-white hover:bg-white hover:text-brand-charcoal text-lg px-8 py-4">
                    <i class="fas fa-phone mr-2"></i>Call Us Now
