{% extends "base.html.twig" %}

{% block title %}Home - Every Event | Premium Catering & Events{% endblock %}

{% block body %}
    <!-- ========== HERO SECTION ========== -->
    <section class="relative min-h-screen bg-brand-charcoal overflow-hidden">
        <!-- Decorative Background Elements -->
        <div class="absolute inset-0 overflow-hidden">
            <div class="decoration-blob w-[600px] h-[600px] top-20 -left-48 opacity-20"></div>
            <div class="decoration-blob w-[500px] h-[500px] bottom-20 right-0 opacity-15"></div>
            <div class="absolute inset-0 bg-gradient-to-br from-brand-charcoal via-brand-charcoal to-brand-brown opacity-90"></div>
        </div>

        <!-- Hero Content -->
        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-20 min-h-screen flex items-center">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center w-full">
                <!-- Left Content -->
                <div class="scroll-animate">
                    <span class="inline-block px-4 py-2 bg-brand-gold/20 text-brand-gold text-sm font-semibold rounded-full mb-6">
                        <i class="fas fa-star mr-2"></i>Premium Catering Experience
                    </span>
                    <h1 class="text-5xl lg:text-6xl xl:text-7xl font-bold text-white mb-6 leading-tight hero-title">
                        Every Event<br>
                        <span class="gold-gradient-text">A Taste of Every</span><br>
                        <span class="text-brand-gold">Occasion</span>
                    </h1>
                    <p class="text-lg text-gray-300 mb-8 leading-relaxed max-w-lg">
                        Experience elegant fine dining with a Filipino touch. From succulent lechon belly to gourmet seafood, every dish is beautifully plated with fresh, high-quality ingredients.
                    </p>
                    <div class="flex flex-wrap gap-4 mb-12">
                        <a href="{{ path('app_contact') }}" class="btn-primary">
                            <i class="fas fa-calendar-check mr-2"></i>Book Now
                        </a>
                        <a href="{{ path('app_menus') }}" class="btn-secondary border-white text-white hover:bg-white hover:text-brand-charcoal">
                            <i class="fas fa-utensils mr-2"></i>View Menu
                        </a>
                    </div>
                    
                    <!-- Stats -->
                    <div class="flex gap-8 sm:gap-12">
                        <div>
                            <p class="text-3xl font-bold text-brand-gold">500+</p>
                            <p class="text-gray-400 text-sm">Events Catered</p>
                        </div>
                        <div>
                            <p class="text-3xl font-bold text-brand-gold">15+</p>
                            <p class="text-gray-400 text-sm">Years Experience</p>
                        </div>
                        <div>
                            <p class="text-3xl font-bold text-brand-gold">100%</p>
                            <p class="text-gray-400 text-sm">Satisfaction</p>
                        </div>
                    </div>
                </div>
                
                <!-- Right Image -->
                <div class="scroll-animate-right delay-300 relative hidden lg:block">
                    <div class="relative">
                        <div class="absolute -inset-4 bg-gradient-to-br from-brand-gold/30 to-brand-orange/30 rounded-3xl blur-2xl"></div>
                        <img src="/images/image.png" alt="Fine Dining Catering Setup" class="relative w-full h-[600px] object-cover rounded-3xl shadow-2xl">
                        <!-- Floating Badge -->
                        <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl p-4 shadow-xl animate-float">
                            <div class="flex items-center gap-3">
                                <div class="w-12 h-12 bg-brand-gold rounded-xl flex items-center justify-center">
                                    <i class="fas fa-award text-white text-xl"></i>
                                </div>
                                <div>
                                    <p class="font-semibold text-brand-charcoal">Award Winning</p>
                                    <p class="text-sm text-gray-500">Catering Service 2025</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Wave Separator -->
        <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none">
            <svg class="relative block w-full h-[80px]" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
                <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" class="fill-brand-cream"></path>
            </svg>
        </div>
    </section>

    <!-- ========== FEATURED SERVICES ========== -->
    <section class="py-24 bg-brand-cream relative overflow-hidden">
        <div class="decoration-blob w-64 h-64 top-10 -right-32 opacity-30"></div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="text-center mb-16 scroll-animate">
                <span class="text-brand-gold font-semibold tracking-wider uppercase text-sm mb-2 block">What We Offer</span>
                <h2 class="text-4xl md:text-5xl font-bold text-brand-charcoal mb-4">Our Premium Services</h2>
                <div class="w-24 h-1 bg-gradient-to-r from-brand-gold to-brand-orange mx-auto rounded-full"></div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Wedding Service -->
                <div class="premium-card group scroll-animate delay-100">
                    <div class="relative h-56 overflow-hidden">
                        <img src="/images/wedding.jpg" alt="Wedding Catering" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                        <div class="absolute bottom-4 left-4">
                            <div class="w-12 h-12 bg-brand-gold rounded-xl flex items-center justify-center">
                                <i class="fas fa-heart text-white"></i>
                            </div>
                        </div>
                    </div>
                    <div class="p-8">
                        <h3 class="text-2xl font-bold text-brand-charcoal mb-3">Weddings</h3>
                        <p class="text-gray-600 mb-4 leading-relaxed">Create unforgettable moments with our premium wedding catering. Elegant presentation and impeccable service.</p>
                        <a href="{{ path('app_services') }}" class="text-brand-gold font-semibold hover:text-brand-gold-dark transition flex items-center gap-2">
                            Learn More <i class="fas fa-arrow-right text-sm"></i>
                        </a>
                    </div>
                </div>

                <!-- Corporate Service -->
                <div class="premium-card group scroll-animate delay-200">
                    <div class="relative h-56 overflow-hidden">
                        <img src="/images/corporate.jpg" alt="Corporate Catering" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                        <div class="absolute bottom-4 left-4">
                            <div class="w-12 h-12 bg-brand-gold rounded-xl flex items-center justify-center">
                                <i class="fas fa-briefcase text-white"></i>
                            </div>
                        </div>
                    </div>
                    <div class="p-8">
                        <h3 class="text-2xl font-bold text-brand-charcoal mb-3">Corporate Events</h3>
                        <p class="text-gray-600 mb-4 leading-relaxed">Professional catering for conferences and celebrations. Impress your clients and colleagues.</p>
                        <a href="{{ path('app_services') }}" class="text-brand-gold font-semibold hover:text-brand-gold-dark transition flex items-center gap-2">
                            Learn More <i class="fas fa-arrow-right text-sm"></i>
                        </a>
                    </div>
                </div>

                <!-- Private Party Service -->
                <div class="premium-card group scroll-animate delay-300">
                    <div class="relative h-56 overflow-hidden">
                        <img src="/images/privateparty.jpg" alt="Private Party Catering" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                        <div class="absolute bottom-4 left-4">
                            <div class="w-12 h-12 bg-brand-gold rounded-xl flex items-center justify-center">
                                <i class="fas fa-glass-cheers text-white"></i>
                            </div>
                        </div>
                    </div>
                    <div class="p-8">
                        <h3 class="text-2xl font-bold text-brand-charcoal mb-3">Private Parties</h3>
                        <p class="text-gray-600 mb-4 leading-relaxed">Intimate celebrations with personalized menus. Perfect for birthdays and special occasions.</p>
                        <a href="{{ path('app_services') }}" class="text-brand-gold font-semibold hover:text-brand-gold-dark transition flex items-center gap-2">
                            Learn More <i class="fas fa-arrow-right text-sm"></i>
                        </a>
                    </div>
                </div>
            </div>
            
            <div class="text-center mt-12 scroll-animate">
                <a href="{{ path('app_services') }}" class="btn-secondary">
                    View All Services <i class="fas fa-arrow-right ml-2"></i>
                </a>
            </div>
        </div>
    </section>

    <!-- ========== FEATURED MENU ITEMS ========== -->
    <section class="py-24 bg-white relative overflow-hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16 scroll-animate">
                <span class="text-brand-gold font-semibold tracking-wider uppercase text-sm mb-2 block">Our Menu</span>
                <h2 class="text-4xl md:text-5xl font-bold text-brand-charcoal mb-4">Signature Dishes</h2>
                <p class="text-gray-600 max-w-2xl mx-auto">Explore our most popular dishes, crafted with passion using the finest ingredients</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <!-- Dish 1 -->
                <div class="menu-item group cursor-pointer scroll-animate delay-100" data-lightbox="/images/lechonbelly.jpg">
                    <img src="/images/lechonbelly.jpg" alt="Lechon Belly" class="h-80">
                    <div class="menu-overlay">
                        <span class="text-brand-gold text-sm font-semibold mb-1">Main Course</span>
                        <h4 class="text-white text-xl font-bold mb-1">Lechon Belly</h4>
                        <p class="text-gray-300 text-sm">Roasted pork perfection with crispy skin</p>
                        <div class="mt-4 flex items-center gap-2 text-brand-gold">
                            <i class="fas fa-search-plus"></i>
                            <span class="text-sm">Click to view</span>
                        </div>
                    </div>
                </div>
                
                <!-- Dish 2 -->
                <div class="menu-item group cursor-pointer scroll-animate delay-200" data-lightbox="/images/seafoods.jpg">
                    <img src="/images/seafoods.jpg" alt="Seafood Sinigang" class="h-80">
                    <div class="menu-overlay">
                        <span class="text-brand-gold text-sm font-semibold mb-1">Soup</span>
                        <h4 class="text-white text-xl font-bold mb-1">Seafood Sinigang</h4>
                        <p class="text-gray-300 text-sm">Gourmet tamarind stew with fresh catch</p>
                        <div class="mt-4 flex items-center gap-2 text-brand-gold">
                            <i class="fas fa-search-plus"></i>
                            <span class="text-sm">Click to view</span>
                        </div>
                    </div>
                </div>
                
                <!-- Dish 3 -->
                <div class="menu-item group cursor-pointer scroll-animate delay-300" data-lightbox="/images/lecheflan.jpg">
                    <img src="/images/lecheflan.jpg" alt="Leche Flan" class="h-80">
                    <div class="menu-overlay">
                        <span class="text-brand-gold text-sm font-semibold mb-1">Dessert</span>
                        <h4 class="text-white text-xl font-bold mb-1">Leche Flan</h4>
                        <p class="text-gray-300 text-sm">Golden custard delight with caramel</p>
                        <div class="mt-4 flex items-center gap-2 text-brand-gold">
                            <i class="fas fa-search-plus"></i>
                            <span class="text-sm">Click to view</span>
                        </div>
                    </div>
                </div>
                
                <!-- Dish 4 -->
                <div class="menu-item group cursor-pointer scroll-animate delay-400" data-lightbox="/images/griledfish.jpg">
                    <img src="/images/griledfish.jpg" alt="Grilled Fish" class="h-80">
                    <div class="menu-overlay">
                        <span class="text-brand-gold text-sm font-semibold mb-1">Seafood</span>
                        <h4 class="text-white text-xl font-bold mb-1">Grilled Catch</h4>
                        <p class="text-gray-300 text-sm">Fresh daily selection, perfectly grilled</p>
                        <div class="mt-4 flex items-center gap-2 text-brand-gold">
                            <i class="fas fa-search-plus"></i>
                            <span class="text-sm">Click to view</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="text-center mt-12 scroll-animate">
                <a href="{{ path('app_menus') }}" class="btn-primary">
                    Explore Full Menu <i class="fas fa-utensils ml-2"></i>
                </a>
            </div>
        </div>
    </section>

    <!-- ========== WHY CHOOSE US ========== -->
    <section class="py-24 bg-brand-cream-dark relative overflow-hidden">
        <div class="decoration-blob w-96 h-96 -top-48 -left-48 opacity-20"></div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <!-- Left Image -->
