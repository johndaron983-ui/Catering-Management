                    <div class="flex text-brand-gold mb-4">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                    </div>
                    <p class="text-gray-600 mb-6 leading-relaxed relative z-10">
                        The corporate catering for our annual gala was outstanding. Professional staff, delicious food, and seamless coordination. We'll definitely be booking with them again!
                    </p>
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-brand-gold/20 rounded-full flex items-center justify-center">
                            <span class="text-brand-gold font-bold">RC</span>
                        </div>
                        <div>
                            <p class="font-semibold text-brand-charcoal">Robert Chen</p>
                            <p class="text-sm text-gray-500">Corporate Event - April 2025</p>
                        </div>
                    </div>
                </div>
                
                <!-- Testimonial 3 -->
