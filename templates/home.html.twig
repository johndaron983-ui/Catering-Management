                    </div>
                    <!-- Experience Badge -->
                    <div class="absolute -bottom-8 -right-8 bg-brand-gold text-white rounded-2xl p-6 shadow-xl scroll-animate delay-300">
                        <p class="text-4xl font-bold">15+</p>
                        <p class="text-sm opacity-90">Years of Excellence</p>
                    </div>
                </div>
                
                <!-- Right Content -->
                <div class="scroll-animate-right">
                    <span class="text-brand-gold font-semibold tracking-wider uppercase text-sm mb-2 block">Why Choose Us</span>
                    <h2 class="text-4xl md:text-5xl font-bold text-brand-charcoal mb-6 leading-tight">
                        Creating Memorable<br>Dining Experiences
                    </h2>
                    <p class="text-gray-600 mb-8 leading-relaxed">
                        Every Event brings an elegant fine dining experience with a Filipino touch. Our carefully curated dishes blend traditional flavors with modern culinary techniques.
                    </p>
                    
                    <!-- Features -->
                    <div class="space-y-6">
                        <div class="flex items-start gap-4">
                            <div class="w-14 h-14 bg-brand-gold/10 rounded-xl flex items-center justify-center flex-shrink-0">
                                <i class="fas fa-leaf text-brand-gold text-xl"></i>
                            </div>
                            <div>
                                <h4 class="font-bold text-brand-charcoal text-lg mb-1">Fresh Ingredients</h4>
                                <p class="text-gray-600 text-sm">We source only the finest, freshest ingredients daily</p>
                            </div>
                        </div>
                        
                        <div class="flex items-start gap-4">
                            <div class="w-14 h-14 bg-brand-gold/10 rounded-xl flex items-center justify-center flex-shrink-0">
                                <i class="fas fa-user-chef text-brand-gold text-xl"></i>
                            </div>
                            <div>
                                <h4 class="font-bold text-brand-charcoal text-lg mb-1">Expert Chefs</h4>
                                <p class="text-gray-600 text-sm">Our culinary team brings years of expertise</p>
                            </div>
                        </div>
                        
                        <div class="flex items-start gap-4">
                            <div class="w-14 h-14 bg-brand-gold/10 rounded-xl flex items-center justify-center flex-shrink-0">
                                <i class="fas fa-palette text-brand-gold text-xl"></i>
                            </div>
                            <div>
                                <h4 class="font-bold text-brand-charcoal text-lg mb-1">Custom Menus</h4>
                                <p class="text-gray-600 text-sm">Tailored to your preferences and dietary needs</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ========== TESTIMONIALS ========== -->
