{% extends "base.html.twig" %}

{% block title %}Services - Every Event | Premium Catering & Events{% endblock %}

{% block body %}
    <!-- ========== HERO SECTION ========== -->
    <section class="relative py-32 bg-brand-charcoal overflow-hidden">
        <div class="absolute inset-0">
            <div class="decoration-blob w-[600px] h-[600px] -top-48 -right-48 opacity-20"></div>
            <div class="decoration-blob w-[400px] h-[400px] bottom-0 left-0 opacity-15"></div>
        </div>
        
        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <span class="inline-block px-4 py-2 bg-brand-gold/20 text-brand-gold text-sm font-semibold rounded-full mb-4 scroll-animate">
                What We Offer
            </span>
            <h1 class="text-5xl md:text-6xl font-bold text-white mb-6 scroll-animate">
                Our <span class="gold-gradient-text">Services</span>
            </h1>
            <p class="text-xl text-gray-300 max-w-2xl mx-auto scroll-animate delay-100">
                Comprehensive catering solutions for every occasion, crafted with passion and precision
            </p>
        </div>
    </section>
    
    <!-- ========== SERVICES GRID ========== -->
    <section class="py-24 bg-brand-cream relative overflow-hidden">
        <div class="decoration-blob w-64 h-64 top-20 -left-32 opacity-20"></div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- Service 1: Weddings -->
                <div class="premium-card group scroll-animate delay-100">
                    <div class="relative h-56 overflow-hidden">
                        <img src="/images/wedding.jpg" alt="Wedding Catering" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
                        <div class="absolute inset-0 bg-gradient-to-t from-brand-charcoal/80 to-transparent"></div>
                        <div class="absolute bottom-4 left-4">
                            <div class="w-14 h-14 bg-brand-gold rounded-2xl flex items-center justify-center">
                                <i class="fas fa-heart text-white text-xl"></i>
                            </div>
                        </div>
                    </div>
                    <div class="p-8">
                        <h3 class="text-2xl font-bold text-brand-charcoal mb-3">Weddings</h3>
                        <p class="text-gray-600 leading-relaxed mb-4 text-sm">
                            Create the perfect culinary backdrop for your special day. We offer customized multi-course menus, elegant presentation, and impeccable service.
                        </p>
                        <ul class="text-gray-600 text-sm space-y-2 mb-6">
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Custom menu design</li>
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Professional staff</li>
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Elegant plating</li>
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Full coordination</li>
                        </ul>
                        <a href="{{ path('app_contact') }}" class="text-brand-gold hover:text-brand-gold-dark font-semibold text-sm flex items-center gap-2">
                            Learn More <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>
                
                <!-- Service 2: Corporate Events -->
                <div class="premium-card group scroll-animate delay-200">
                    <div class="relative h-56 overflow-hidden">
                        <img src="/images/corporate.jpg" alt="Corporate Events Catering" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
                        <div class="absolute inset-0 bg-gradient-to-t from-brand-charcoal/80 to-transparent"></div>
                        <div class="absolute bottom-4 left-4">
                            <div class="w-14 h-14 bg-brand-gold rounded-2xl flex items-center justify-center">
                                <i class="fas fa-briefcase text-white text-xl"></i>
                            </div>
                        </div>
                    </div>
                    <div class="p-8">
                        <h3 class="text-2xl font-bold text-brand-charcoal mb-3">Corporate Events</h3>
                        <p class="text-gray-600 leading-relaxed mb-4 text-sm">
                            Impress your clients and colleagues with professional catering for conferences, meetings, awards banquets, and team celebrations.
                        </p>
                        <ul class="text-gray-600 text-sm space-y-2 mb-6">
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Flexible scheduling</li>
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Bulk capabilities</li>
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Professional delivery</li>
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Custom pricing</li>
                        </ul>
                        <a href="{{ path('app_contact') }}" class="text-brand-gold hover:text-brand-gold-dark font-semibold text-sm flex items-center gap-2">
                            Learn More <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>
                
                <!-- Service 3: Private Parties -->
                <div class="premium-card group scroll-animate delay-300">
                    <div class="relative h-56 overflow-hidden">
                        <img src="/images/privateparty.jpg" alt="Private Party Catering" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
                        <div class="absolute inset-0 bg-gradient-to-t from-brand-charcoal/80 to-transparent"></div>
                        <div class="absolute bottom-4 left-4">
                            <div class="w-14 h-14 bg-brand-gold rounded-2xl flex items-center justify-center">
                                <i class="fas fa-glass-cheers text-white text-xl"></i>
                            </div>
                        </div>
                    </div>
                    <div class="p-8">
                        <h3 class="text-2xl font-bold text-brand-charcoal mb-3">Private Parties</h3>
                        <p class="text-gray-600 leading-relaxed mb-4 text-sm">
                            Whether it's an anniversary or intimate gathering, we create personalized experiences with carefully selected menus that delight.
                        </p>
                        <ul class="text-gray-600 text-sm space-y-2 mb-6">
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Customized menus</li>
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Intimate settings</li>
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Flexible sizes</li>
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Personal service</li>
                        </ul>
                        <a href="{{ path('app_contact') }}" class="text-brand-gold hover:text-brand-gold-dark font-semibold text-sm flex items-center gap-2">
                            Learn More <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>
                
                <!-- Service 4: Birthday Celebrations -->
                <div class="premium-card group scroll-animate delay-100">
                    <div class="relative h-56 overflow-hidden">
                        <img src="/images/bday.jpg" alt="Birthday Party Catering" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
                        <div class="absolute inset-0 bg-gradient-to-t from-brand-charcoal/80 to-transparent"></div>
                        <div class="absolute bottom-4 left-4">
                            <div class="w-14 h-14 bg-brand-gold rounded-2xl flex items-center justify-center">
                                <i class="fas fa-birthday-cake text-white text-xl"></i>
                            </div>
                        </div>
                    </div>
                    <div class="p-8">
                        <h3 class="text-2xl font-bold text-brand-charcoal mb-3">Birthday Celebrations</h3>
                        <p class="text-gray-600 leading-relaxed mb-4 text-sm">
                            Make birthdays extra special with themed menus, elegant presentations, and memorable dining experiences tailored to the guest of honor.
                        </p>
                        <ul class="text-gray-600 text-sm space-y-2 mb-6">
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Themed menus</li>
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Dessert packages</li>
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Special arrangements</li>
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Budget options</li>
                        </ul>
                        <a href="{{ path('app_contact') }}" class="text-brand-gold hover:text-brand-gold-dark font-semibold text-sm flex items-center gap-2">
                            Learn More <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>
                
                <!-- Service 5: Engagement Parties -->
                <div class="premium-card group scroll-animate delay-200">
                    <div class="relative h-56 overflow-hidden">
                        <img src="/images/engagement.jpeg" alt="Engagement Party Catering" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
                        <div class="absolute inset-0 bg-gradient-to-t from-brand-charcoal/80 to-transparent"></div>
                        <div class="absolute bottom-4 left-4">
                            <div class="w-14 h-14 bg-brand-gold rounded-2xl flex items-center justify-center">
                                <i class="fas fa-gem text-white text-xl"></i>
                            </div>
                        </div>
                    </div>
                    <div class="p-8">
                        <h3 class="text-2xl font-bold text-brand-charcoal mb-3">Engagement Parties</h3>
                        <p class="text-gray-600 leading-relaxed mb-4 text-sm">
                            Celebrate your engagement with elegance. Our curated menus and sophisticated ambiance create the perfect setting for this milestone.
                        </p>
                        <ul class="text-gray-600 text-sm space-y-2 mb-6">
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Elegant settings</li>
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Romantic menus</li>
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Premium service</li>
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Full coordination</li>
                        </ul>
                        <a href="{{ path('app_contact') }}" class="text-brand-gold hover:text-brand-gold-dark font-semibold text-sm flex items-center gap-2">
                            Learn More <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>
                
                <!-- Service 6: Customized Catering -->
                <div class="premium-card group scroll-animate delay-300">
                    <div class="relative h-56 overflow-hidden">
                        <img src="/images/customized.jpg" alt="Customized Catering" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
                        <div class="absolute inset-0 bg-gradient-to-t from-brand-charcoal/80 to-transparent"></div>
                        <div class="absolute bottom-4 left-4">
                            <div class="w-14 h-14 bg-brand-gold rounded-2xl flex items-center justify-center">
                                <i class="fas fa-magic text-white text-xl"></i>
                            </div>
                        </div>
                    </div>
                    <div class="p-8">
                        <h3 class="text-2xl font-bold text-brand-charcoal mb-3">Customized Catering</h3>
                        <p class="text-gray-600 leading-relaxed mb-4 text-sm">
                            Have a unique event in mind? We specialize in creating bespoke catering experiences tailored specifically to your vision and dietary needs.
                        </p>
                        <ul class="text-gray-600 text-sm space-y-2 mb-6">
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Fully customized</li>
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Dietary accommodation</li>
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Creative menus</li>
                            <li class="flex items-center"><i class="fas fa-check text-brand-gold mr-2"></i> Personal consultation</li>
                        </ul>
                        <a href="{{ path('app_contact') }}" class="text-brand-gold hover:text-brand-gold-dark font-semibold text-sm flex items-center gap-2">
                            Learn More <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- ========== PROCESS SECTION ========== -->
    <section class="py-24 bg-white relative overflow-hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16 scroll-animate">
                <span class="text-brand-gold font-semibold tracking-wider uppercase text-sm mb-2 block">How It Works</span>
                <h2 class="text-4xl md:text-5xl font-bold text-brand-charcoal mb-4">Our Process</h2>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    Simple steps to your perfect catering experience
                </p>
                <div class="w-24 h-1 bg-gradient-to-r from-brand-gold to-brand-orange mx-auto mt-6 rounded-full"></div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
                <div class="text-center scroll-animate delay-100">
                    <div class="w-20 h-20 bg-gradient-to-br from-brand-gold to-brand-gold-dark rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg">
                        <span class="text-white font-bold text-2xl">1</span>
                    </div>
                    <h3 class="text-xl font-bold text-brand-charcoal mb-3">Consultation</h3>
                    <p class="text-gray-600 text-sm">Discuss your vision, preferences, and requirements with our team</p>
                </div>
                
                <div class="text-center scroll-animate delay-200">
                    <div class="w-20 h-20 bg-gradient-to-br from-brand-gold to-brand-gold-dark rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg">
                        <span class="text-white font-bold text-2xl">2</span>
                    </div>
                    <h3 class="text-xl font-bold text-brand-charcoal mb-3">Menu Planning</h3>
                    <p class="text-gray-600 text-sm">We create a customized menu tailored to your event and budget</p>
                </div>
                
                <div class="text-center scroll-animate delay-300">
                    <div class="w-20 h-20 bg-gradient-to-br from-brand-gold to-brand-gold-dark rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg">
                        <span class="text-white font-bold text-2xl">3</span>
                    </div>
                    <h3 class="text-xl font-bold text-brand-charcoal mb-3">Preparation</h3>
                    <p class="text-gray-600 text-sm">Our expert chefs prepare your dishes with the finest ingredients</p>
                </div>
                
                <div class="text-center scroll-animate delay-400">
                    <div class="w-20 h-20 bg-gradient-to-br from-brand-gold to-brand-gold-dark rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg">
                        <span class="text-white font-bold text-2xl">4</span>
                    </div>
                    <h3 class="text-xl font-bold text-brand-charcoal mb-3">Execution</h3>
                    <p class="text-gray-600 text-sm">We deliver and serve with impeccable presentation and service</p>
                </div>
            </div>
        </div>
    </section>
    
    <!-- ========== CTA SECTION ========== -->
    <section class="py-24 bg-brand-charcoal relative overflow-hidden">
        <div class="absolute inset-0">
            <div class="decoration-blob w-[500px] h-[500px] top-0 right-0 opacity-10"></div>
            <div class="decoration-blob w-[400px] h-[400px] bottom-0 left-0 opacity-10"></div>
        </div>
        
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10 scroll-animate">
            <span class="inline-block px-4 py-2 bg-brand-gold/20 text-brand-gold text-sm font-semibold rounded-full mb-6">
                Ready to Book?
            </span>
            <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
                Ready to Book Your <span class="gold-gradient-text">Event?</span>
            </h2>
            <p class="text-gray-300 text-lg mb-10 max-w-2xl mx-auto">
                Contact us today to discuss your catering needs and get a custom quote for your special occasion.
            </p>
            <a href="{{ path('app_contact') }}" class="btn-primary text-lg px-8 py-4">
                <i class="fas fa-calendar-check mr-2"></i>Get in Touch
            </a>
        </div>
    </section>
{% endblock %}
