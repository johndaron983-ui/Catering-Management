}, 500);

// INITIALIZE BOOKING PERIOD SELECTOR 
document.addEventListener('turbo:load', function() {
    console.log('Turbo load event, initializing booking period selector...');
    initializeBookingPeriodSelector();
});

// FALLBACK FOR NON-TURBO NAVIGATION
document.addEventListener('DOMContentLoaded', function() {
    console.log('DOM loaded, initializing booking period selector...');
    initializeBookingPeriodSelector();
});

function initializeBookingPeriodSelector() {
    const bookingPeriodSelect = document.getElementById('booking-period-select');
    
    if (!bookingPeriodSelect) {
        console.log('Booking period selector not found');
        return;
    }
    
    // REMOVE ANY EXISTING EVENT LISTENERS BY CLONING 
    const newSelect = bookingPeriodSelect.cloneNode(true);
    bookingPeriodSelect.parentNode.replaceChild(newSelect, bookingPeriodSelect);
    
    // ADD EVENT LISTENER FOR PERIOD CHANGE
    newSelect.addEventListener('change', function() {
        const period = this.value;
        console.log('Booking period changed to:', period);
        
        // UPDATE BOOKING CHART WITH NEW DATA
        updateBookingChartData(period);
    });
    
    console.log('Booking period selector initialized');
}

async function updateBookingChartData(period) {
    const canvas = document.getElementById('bookingChart');
    if (!canvas) {
        console.log('Booking chart canvas not found');
        return;
    }
    
    try {
        // SHOW LOADING STATE
        canvas.style.opacity = '0.5';
        
        console.log('Fetching booking data for period:', period);
        
        // FETCH NEW DATA
        const response = await fetch(`/admin/dashboard/chart-data?period=${period}`);
        
        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }
        
        const data = await response.json();
        console.log('Fetched booking data:', data);
        
        if (data.success === false) {
            throw new Error(data.message || 'Server returned error');
        }
        
        // UDATE THE BOOKING CHART
        updateBookingChart(data);
        
        // HIDE LOADING STATE
        canvas.style.opacity = '1';
        
    } catch (error) {
        console.error('Error fetching booking chart data:', error);
        
        // SHOW ERROR MESSAGE 
        showChartError('booking', error.message);
        
        // HIDE LOADING STATE 
        canvas.style.opacity = '1';
    }
}

// INTERACTIVE PERIOD BUTTONS FUNCTIONALITY - TURBO COMPATIBLE
document.addEventListener('turbo:load', function() {
    console.log('Turbo load event, initializing period buttons...');
    initializePeriodButtons();
});

// FALLBACK FOR NON-TURBO NAVIGATION
document.addEventListener('DOMContentLoaded', function() {
    console.log('DOM loaded, initializing period buttons...');
    initializePeriodButtons();
});

function initializePeriodButtons() {
    const periodButtons = document.querySelectorAll('.period-btn');
    
    console.log(`Found ${periodButtons.length} period buttons to initialize`);
    
    periodButtons.forEach(button => {
        // REMOVE ANY EXISTING EVENT LISTENERS BY CLONING THE ELEMENT
        const newButton = button.cloneNode(true);
        button.parentNode.replaceChild(newButton, button);
        
        // ADD FRESH EVENT LISTENER
        newButton.addEventListener('click', function() {
            const period = this.getAttribute('data-period');
            const chartType = this.id.startsWith('revenue') ? 'revenue' : 'booking';
            
            console.log(`Period button clicked: ${period} for ${chartType} chart`);
            
            // UPDATE BUTTON STATES
            updateButtonStates(this);
            
            // FETCH NEW DATA AND UPDATE CHART
            updateChartData(chartType, period);
        });
        
        console.log(`Initialized button: ${newButton.id} with period ${newButton.getAttribute('data-period')}`);
    });
}

function updateButtonStates(activeButton) {
    const allButtons = document.querySelectorAll('.period-btn');
    
    allButtons.forEach(button => {
        button.classList.remove('bg-[#235A2F]', 'text-white');
        button.classList.add('bg-gray-100', 'text-gray-600');
    });
    
    activeButton.classList.remove('bg-gray-100', 'text-gray-600');
    activeButton.classList.add('bg-[#235A2F]', 'text-white');
}

async function updateChartData(chartType, period) {
    let canvas = null;
    const requestKey = `${chartType}-${period}`;
    
    // PREVENT DUPLICATE REQUESTS
    if (window.dashboardCharts.pendingRequests.has(requestKey)) {
        console.log(`Request for ${requestKey} already pending, skipping...`);
        return;
    }
    
    try {
        // ADD TO PENDING REQUESTS
        window.dashboardCharts.pendingRequests.add(requestKey);
        
        // SHOW LOADING STATE - WITH NULL CHECK
        canvas = document.getElementById(chartType + 'Chart');
        if (canvas && canvas.style) {
            canvas.style.opacity = '0.5';
        }
        
        console.log(`Fetching data for ${chartType} chart with period ${period}`);
        
        // FETCH NEW DATA
        const response = await fetch(`/admin/dashboard/chart-data?period=${period}`);
        
        console.log('Response status:', response.status);
        
        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }
        
        const text = await response.text();
        console.log('Raw response:', text);
        
        let data;
        try {
            data = JSON.parse(text);
        } catch (parseError) {
            console.error('JSON parse error:', parseError);
            console.error('Response text:', text);
            throw new Error('Invalid JSON response');
        }
        
        console.log(`Fetched data for ${period}:`, data);
        
        if (data.success === false) {
            throw new Error(data.message || 'Server returned error');
        }
        
        // CHECK IF CANVAS STILL EXISTS BEFORE UPDATING CHART
        canvas = document.getElementById(chartType + 'Chart');
        if (!canvas) {
            console.warn(`Canvas ${chartType}Chart not found, skipping chart update`);
            return;
        }
        
        // UPDATE THE APPROPRIATE CHART
        if (chartType === 'revenue') {
            updateRevenueChart(data);
        } else if (chartType === 'booking') {
            updateBookingChart(data);
        }
        
        // HIDE LOADING STATE - WITH NULL CHECK
        if (canvas && canvas.style) {
            canvas.style.opacity = '1';
        }
        
    } catch (error) {
        console.error('Error fetching chart data:', error);
        console.error('Error details:', error.message);
        
        // SHOW ERROR MESSAGE TO USER
        showChartError(chartType, error.message);
        
        // HIDE LOADING STATE - WITH NULL CHECK
        canvas = document.getElementById(chartType + 'Chart');
        if (canvas && canvas.style) {
            canvas.style.opacity = '1';
        }
    } finally {
        // ALWAYS REMOVE FROM PENDING REQUESTS
        window.dashboardCharts.pendingRequests.delete(requestKey);
    }
}

function showChartError(chartType, message) {
    const canvas = document.getElementById(chartType + 'Chart');
    if (canvas && canvas.parentNode) {
        // CREATE ERROR MESSAGE
        let errorDiv = canvas.parentNode.querySelector('.chart-error');
        if (!errorDiv) {
            errorDiv = document.createElement('div');
            errorDiv.className = 'chart-error absolute inset-0 flex items-center justify-center bg-red-50 text-red-600 text-sm';
            canvas.parentNode.style.position = 'relative';
            canvas.parentNode.appendChild(errorDiv);
        }
        errorDiv.textContent = `Error: ${message}`;
        errorDiv.style.display = 'flex';
        
        // HIDE ERROR AFTER 5 SECONDS
        setTimeout(() => {
            errorDiv.style.display = 'none';
        }, 5000);
    }
}

function updateRevenueChart(data) {
    // CHECK IF CHART EXISTS AND CANVAS STILL EXISTS
    if (!window.dashboardCharts.revenueChart) {
        console.log('Revenue chart not found, cannot update');
        return;
    }
    
    const canvas = document.getElementById('revenueChart');
    if (!canvas) {
        console.log('Revenue chart canvas not found, cannot update');
        return;
    }
    
    try {
        // GENERATE APPROPRIATE LABELS BASED ON PERIOD
        let labels = [];
        if (data.period === '7D') {
            // LAST 7 DAYS
            for (let i = 6; i >= 0; i--) {
                const date = new Date();
                date.setDate(date.getDate() - i);
                labels.push(date.toLocaleDateString('en-US', { weekday: 'short' }));
            }
        } else if (data.period === '30D') {
            // LAST 4 WEEKS
            labels = ['Week 1', 'Week 2', 'Week 3', 'Week 4'];
        } else if (data.period === '90D') {
            // LAST 3 MONTHS
            labels = ['Month 1', 'Month 2', 'Month 3'];
        }
        
        // UPDATE CHART DATA
        window.dashboardCharts.revenueChart.data.labels = labels;
        window.dashboardCharts.revenueChart.data.datasets[0].data = data.revenue;
        
        // UPDATE CHART
        window.dashboardCharts.revenueChart.update('active');
        
        console.log('Revenue chart updated with new data for period:', data.period);
    } catch (error) {
        console.error('Error updating revenue chart:', error);
    }
}

function updateBookingChart(data) {
    // CHECK IF CHART EXISTS AND CANVAS STILL EXISTS
    if (!window.dashboardCharts.bookingChart) {
        console.log('Booking chart not found, cannot update');
        return;
    }
    
    const canvas = document.getElementById('bookingChart');
    if (!canvas) {
        console.log('Booking chart canvas not found, cannot update');
        return;
    }
    
    try {
        // GENERATE APPROPRIATE LABELS BASED ON PERIOD
        let labels = [];
        if (data.period === '7D') {
            // LAST 7 DAYS
            for (let i = 6; i >= 0; i--) {
                const date = new Date();
                date.setDate(date.getDate() - i);
                labels.push(date.toLocaleDateString('en-US', { weekday: 'short' }));
            }
        } else if (data.period === '30D') {
            // LAST 4 WEEKS
            labels = ['Week 1', 'Week 2', 'Week 3', 'Week 4'];
        } else if (data.period === '90D') {
            // LAST 3 MONTHS
            labels = ['Month 1', 'Month 2', 'Month 3'];
        }
        
        //  UPDATE CHART DATA
        window.dashboardCharts.bookingChart.data.labels = labels;
        window.dashboardCharts.bookingChart.data.datasets[0].data = data.bookings;
        
        // UPDATE CHART
        window.dashboardCharts.bookingChart.update('active');
        
        console.log('Booking chart updated with new data for period:', data.period);
    } catch (error) {
        console.error('Error updating booking chart:', error);
    }
}
