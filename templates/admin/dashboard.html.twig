</div>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
function formatPeso(value) {
    try {
        return Number(value).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    } catch (e) {
        return String(value);
    }
}

function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

function statusBadgeClasses(status) {
    const s = (status || '').toLowerCase();
    if (s === 'confirmed') return 'bg-green-100 text-green-800';
    if (s === 'pending') return 'bg-yellow-100 text-yellow-800';
    if (s === 'processing') return 'bg-blue-100 text-blue-800';
    if (s === 'completed') return 'bg-gray-100 text-gray-800';
    return 'bg-red-100 text-red-800';
}

function serviceEmoji(name) {
    const n = (name || '').toLowerCase();
    if (n.includes('wedding')) return '💒';
    if (n.includes('corporate') || n.includes('business')) return '🏢';
    if (n.includes('birthday') || n.includes('party')) return '🎉';
    return '🍽️';
}

function getLast7DayLabels() {
    const labels = [];
    for (let i = 6; i >= 0; i--) {
        const date = new Date();
        date.setDate(date.getDate() - i);
        labels.push(date.toLocaleDateString('en-US', { weekday: 'short' }));
    }
    return labels;
}

function renderTopServices(services) {
    const container = document.getElementById('top-services-list');
    if (!container) return;

    if (!services || !services.length) {
        container.innerHTML = '<div class="text-center py-8 text-gray-500"><div class="text-4xl mb-2">📊</div><div>No service data available</div></div>';
        return;
    }

    container.innerHTML = services.map(function(s) {
        const img = s.image
            ? '<img src="' + escapeHtml(s.image) + '" alt="' + escapeHtml(s.name) + '" class="h-full w-full object-cover">'
            : '<span class="text-gray-600 text-lg">' + serviceEmoji(s.name) + '</span>';
        return '<div class="flex items-center justify-between">' +
            '<div class="flex items-center space-x-3">' +
            '<div class="h-12 w-12 rounded-full overflow-hidden bg-gray-100 flex items-center justify-center">' + img + '</div>' +
            '<div><div class="font-medium text-gray-800">' + escapeHtml(s.name) + '</div>' +
            '<div class="text-sm text-gray-500">' + s.booking_count + ' booking' + (s.booking_count === 1 ? '' : 's') + '</div></div></div>' +
            '<div class="text-right"><div class="font-semibold text-gray-800">₱' + formatPeso(s.total_revenue) + '</div>' +
            '<div class="text-xs text-green-600">Base: ₱' + Number(s.base_price).toLocaleString('en-US', { maximumFractionDigits: 0 }) + '</div></div></div>';
    }).join('');
}

function renderRecentBookings(bookings) {
    const container = document.getElementById('recent-bookings-list');
    if (!container) return;

    if (!bookings || !bookings.length) {
        container.innerHTML = '<div class="text-center py-8 text-gray-500"><div class="text-4xl mb-2">📅</div><div>No recent bookings</div></div>';
        return;
    }

    container.innerHTML = bookings.map(function(b, index) {
        const border = index < bookings.length - 1 ? 'border-b border-gray-100' : '';
        const statusLabel = (b.status || 'pending').charAt(0).toUpperCase() + (b.status || 'pending').slice(1);
        return '<div class="flex items-center justify-between py-2 ' + border + '">' +
            '<div><div class="font-medium text-gray-800">' + escapeHtml(b.customer_name) + '</div>' +
            '<div class="text-sm text-gray-500">' + escapeHtml(b.service_name) + ' • ' + escapeHtml(b.event_date_short) + '</div>' +
            '<div class="text-xs text-gray-400">' + b.guest_count + ' guests • ₱' + formatPeso(b.total_price) + '</div></div>' +
            '<span class="text-xs px-2 py-1 rounded-full ' + statusBadgeClasses(b.status) + '">' + escapeHtml(statusLabel) + '</span></div>';
    }).join('');
}

function updateDashboardCharts(snapshot) {
    const labels = getLast7DayLabels();

    if (window.dashboardCharts.revenueChart && Array.isArray(snapshot.revenue7d)) {
        window.dashboardCharts.revenueChart.data.labels = labels;
        window.dashboardCharts.revenueChart.data.datasets[0].data = snapshot.revenue7d;
        window.dashboardCharts.revenueChart.update('none');
    }

    if (window.dashboardCharts.bookingChart && Array.isArray(snapshot.bookings7d)) {
        window.dashboardCharts.bookingChart.data.labels = labels;
        window.dashboardCharts.bookingChart.data.datasets[0].data = snapshot.bookings7d;
        window.dashboardCharts.bookingChart.update('none');
    }
}

function applyDashboardSnapshot(data) {
    if (!data || !data.success) return;

    const revenueEl = document.getElementById('kpi-total-revenue');
    if (revenueEl && typeof data.totalRevenue !== 'undefined') {
        revenueEl.setAttribute('data-value', String(data.totalRevenue));
        revenueEl.textContent = formatPeso(data.totalRevenue);
    }

    const revenueGrowthEl = document.getElementById('kpi-revenue-growth');
    if (revenueGrowthEl && typeof data.revenueGrowth !== 'undefined') {
        const g = Number(data.revenueGrowth);
        revenueGrowthEl.textContent = (g >= 0 ? '+' : '') + g + '% vs last month';
        revenueGrowthEl.className = 'mt-1 text-sm ' + (g >= 0 ? 'text-green-600' : 'text-red-600');
    }

    const activeEl = document.getElementById('kpi-active-bookings');
    if (activeEl && typeof data.activeBookings !== 'undefined') {
        activeEl.textContent = String(data.activeBookings);
    }

    const bookingGrowthEl = document.getElementById('kpi-booking-growth');
    if (bookingGrowthEl && typeof data.bookingGrowth !== 'undefined') {
        const g = Number(data.bookingGrowth);
        bookingGrowthEl.textContent = (g >= 0 ? '+' : '') + g + ' this week';
        bookingGrowthEl.className = 'mt-1 text-sm ' + (g >= 0 ? 'text-blue-600' : 'text-red-600');
    }

    const pendingEl = document.getElementById('kpi-pending-requests');
    if (pendingEl && typeof data.pendingRequests !== 'undefined') {
        pendingEl.textContent = String(data.pendingRequests);
    }

    const pendingAlertEl = document.getElementById('system-alert-pending-text');
    if (pendingAlertEl && typeof data.pendingRequests !== 'undefined') {
        const n = Number(data.pendingRequests);
        pendingAlertEl.textContent = n + ' pending booking request' + (n === 1 ? '' : 's') + ' require your attention';
    }

    if (data.recentBookings) {
        renderRecentBookings(data.recentBookings);
    }

    if (data.topServices) {
        renderTopServices(data.topServices);
    }

    updateDashboardCharts(data);
}

window.addEventListener('admin:booking_created', function() {
    if (typeof window.__refreshDashboardSnapshot === 'function') {
        window.__refreshDashboardSnapshot();
    }
});

(function startDashboardPolling() {
    if (window.__dashboardPollingActive) return;
    window.__dashboardPollingActive = true;

    let afterId = Number({{ max_booking_id }}) || 0;
    let isRunning = false;
    let pollTimer = null;

    async function tick() {
        if (isRunning) return;
        isRunning = true;
        try {
            const res = await fetch('/admin/realtime/snapshot?afterId=' + afterId, {
                headers: { 'Accept': 'application/json' }
            });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            const data = await res.json();
            if (data && data.success) {
                afterId = Math.max(afterId, Number(data.latestId || afterId));
                applyDashboardSnapshot(data);
            }
        } catch (e) {
            // retry next tick
        } finally {
            isRunning = false;
            pollTimer = setTimeout(tick, 2000);
        }
    }

    window.__refreshDashboardSnapshot = tick;

    document.addEventListener('turbo:before-cache', function() {
        if (pollTimer) clearTimeout(pollTimer);
        window.__dashboardPollingActive = false;
        window.__refreshDashboardSnapshot = null;
    });

    pollTimer = setTimeout(tick, 1500);
})();

// Use window object to store chart instances to avoid redeclaration issues
if (!window.dashboardCharts) {
    window.dashboardCharts = {
        revenueChart: null,
        bookingChart: null,
        pendingRequests: new Set()
    };
}

// Function to initialize charts
function initializeDashboardCharts() {
    // Destroy existing charts if they exist
    if (window.dashboardCharts.revenueChart) {
        window.dashboardCharts.revenueChart.destroy();
        window.dashboardCharts.revenueChart = null;
    }
    if (window.dashboardCharts.bookingChart) {
        window.dashboardCharts.bookingChart.destroy();
        window.dashboardCharts.bookingChart = null;
    }

    // CHECK IF CANVAS ELEMENTS EXIST
    const revenueCanvas = document.getElementById('revenueChart');
    const bookingCanvas = document.getElementById('bookingChart');

    if (!revenueCanvas || !bookingCanvas) {
        console.log('Canvas elements not found, retrying in 100ms...');
        setTimeout(initializeDashboardCharts, 100);
        return;
    }

    // REVENUE CHART
    const revenueCtx = revenueCanvas.getContext('2d');
    const revenueData = {{ monthlyRevenue|json_encode|raw }};
    
    // Debug: Log the revenue data
    console.log('Revenue data from server:', revenueData);
    
    // Get last 7 days for labels 
    const last7Days = [];
    for (let i = 6; i >= 0; i--) {
        const date = new Date();
        date.setDate(date.getDate() - i);
        last7Days.push(date.toLocaleDateString('en-US', { weekday: 'short' }));
    }
    
    console.log('Revenue chart labels:', last7Days);
    console.log('Revenue chart data:', revenueData);
    
    window.dashboardCharts.revenueChart = new Chart(revenueCtx, {
        type: 'line',
        data: {
