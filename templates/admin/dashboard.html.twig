{% extends 'admin/layout.html.twig' %}

{% block admin_body %}
{# Track the max booking id already rendered (prevents polling from treating existing records as new). #}
{% set max_booking_id = 0 %}
{% for booking in recentBookings %}
    {% if booking.id > max_booking_id %}
        {% set max_booking_id = booking.id %}
    {% endif %}
{% endfor %}

<!-- KPI CARDS WIDGETS -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-100 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between">
            <div>
                <div class="text-gray-500 text-sm font-medium">Total Revenue</div>
                <div class="mt-2 text-3xl font-bold text-gray-800">
                    ₱<span id="kpi-total-revenue" data-value="{{ totalRevenue }}">{{ totalRevenue|number_format(2, '.', ',') }}</span>
                </div>
                <div id="kpi-revenue-growth" class="mt-1 text-sm {{ revenueGrowth >= 0 ? 'text-green-600' : 'text-red-600' }}">
                    {{ revenueGrowth >= 0 ? '+' : '' }}{{ revenueGrowth }}% vs last month
                </div>
            </div>
            <div class="h-12 w-12 bg-green-100 rounded-full flex items-center justify-center">
                <span class="text-green-600 text-xl">💰</span>
            </div>
        </div>
    </div>
    
    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-100 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between">
            <div>
                <div class="text-gray-500 text-sm font-medium">Active Bookings</div>
                <div id="kpi-active-bookings" class="mt-2 text-3xl font-bold text-gray-800">{{ activeBookings }}</div>
                <div id="kpi-booking-growth" class="mt-1 text-sm {{ bookingGrowth >= 0 ? 'text-blue-600' : 'text-red-600' }}">
                    {{ bookingGrowth >= 0 ? '+' : '' }}{{ bookingGrowth }} this week
                </div>
            </div>
            <div class="h-12 w-12 bg-blue-100 rounded-full flex items-center justify-center">
                <span class="text-blue-600 text-xl">📅</span>
            </div>
        </div>
    </div>
    
    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-100 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between">
            <div>
                <div class="text-gray-500 text-sm font-medium">Pending Requests</div>
                <div id="kpi-pending-requests" class="mt-2 text-3xl font-bold text-gray-800">{{ pendingRequests }}</div>
                <div class="mt-1 text-sm text-orange-600">Requires attention</div>
            </div>
            <div class="h-12 w-12 bg-orange-100 rounded-full flex items-center justify-center">
                <span class="text-orange-600 text-xl">⏳</span>
            </div>
        </div>
    </div>
    
    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-100 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between">
            <div>
                <div class="text-gray-500 text-sm font-medium">Customer Rating</div>
                <div class="mt-2 text-3xl font-bold text-gray-800">4.8</div>
                <div class="mt-1 text-sm text-green-600">Excellent</div>
            </div>
            <div class="h-12 w-12 bg-yellow-100 rounded-full flex items-center justify-center">
                <span class="text-yellow-600 text-xl">⭐</span>
            </div>
        </div>
    </div>
</div>

<!-- CHARTS AND GRAPHS -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- REVENUE CHART WIDGET -->
    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-100">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold text-gray-800">Revenue Trend</h3>
            <div class="flex space-x-2">
                <button id="revenue-7d" class="period-btn px-3 py-1 text-xs bg-gray-100 text-gray-600 rounded-md hover:bg-gray-200 transition-colors" data-period="7D">7D</button>
                <button id="revenue-30d" class="period-btn px-3 py-1 text-xs bg-[#235A2F] text-white rounded-md transition-colors" data-period="30D">30D</button>
                <button id="revenue-90d" class="period-btn px-3 py-1 text-xs bg-gray-100 text-gray-600 rounded-md hover:bg-gray-200 transition-colors" data-period="90D">90D</button>
            </div>
        </div>
        <div class="h-64">
            <canvas id="revenueChart"></canvas>
        </div>
    </div>

    <!-- BOOKING TRENDS CHART WIDGET -->
    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-100">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold text-gray-800">Booking Trends</h3>
            <select id="booking-period-select" class="text-sm border border-gray-200 rounded-md px-2 py-1">
                <option value="7D">This Week</option>
                <option value="30D" selected>This Month</option>
                <option value="90D">This Quarter</option>
            </select>
        </div>
        <div class="h-64">
            <canvas id="bookingChart"></canvas>
        </div>
    </div>
</div>

<!-- SERVICES PERFORMANCE AND RECENT BOOKINGS -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    <!-- SERVICES PERFOMANCE WIDGET -->
    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-100">
        <h3 class="text-lg font-semibold text-gray-800 mb-4">Top Services</h3>
        <div id="top-services-list" class="space-y-4">
            {% for service in topServices %}
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="h-12 w-12 rounded-full overflow-hidden bg-gray-100 flex items-center justify-center">
                        {% if service.image %}
                            <img src="{{ asset('image/' ~ service.image) }}" alt="{{ service.name }}" class="h-full w-full object-cover">
                        {% else %}
                            <span class="text-gray-600 text-lg">
                                {% if 'wedding' in service.name|lower %}
                                    💒
                                {% elseif 'corporate' in service.name|lower or 'business' in service.name|lower %}
                                    🏢
                                {% elseif 'birthday' in service.name|lower or 'party' in service.name|lower %}
                                    🎉
                                {% else %}
                                    🍽️
                                {% endif %}
                            </span>
                        {% endif %}
                    </div>
                    <div>
                        <div class="font-medium text-gray-800">{{ service.name }}</div>
                        <div class="text-sm text-gray-500">{{ service.bookingCount }} bookings</div>
                    </div>
                </div>
                <div class="text-right">
                    <div class="font-semibold text-gray-800">₱{{ service.totalRevenue|number_format(2, '.', ',') }}</div>
                    <div class="text-xs text-green-600">Base: ₱{{ service.basePrice|number_format(0, '.', ',') }}</div>
                </div>
            </div>
            {% endfor %}
            
            {% if topServices|length == 0 %}
            <div class="text-center py-8 text-gray-500">
                <div class="text-4xl mb-2">📊</div>
                <div>No service data available</div>
            </div>
            {% endif %}
        </div>
    </div>

    <!-- RECENT BOOKINGS WIDGET -->
    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-100">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold text-gray-800">Recent Bookings</h3>
            <a href="{{ path('app_bookings_index') }}" class="text-sm text-[#235A2F] hover:underline">View all</a>
        </div>
        <div id="recent-bookings-list" class="space-y-3">
            {% for booking in recentBookings %}
            <div class="flex items-center justify-between py-2 {{ loop.last ? '' : 'border-b border-gray-100' }}">
                <div>
                    <div class="font-medium text-gray-800">{{ booking.customerName }}</div>
                    <div class="text-sm text-gray-500">{{ booking.service.name }} • {{ booking.eventDate|date('M d') }}</div>
                    <div class="text-xs text-gray-400">{{ booking.guestCount }} guests • ₱{{ booking.totalPrice|number_format(2, '.', ',') }}</div>
                </div>
                <span class="text-xs px-2 py-1 rounded-full 
                    {% if booking.status == 'confirmed' %}bg-green-100 text-green-800
                    {% elseif booking.status == 'pending' %}bg-yellow-100 text-yellow-800
                    {% elseif booking.status == 'processing' %}bg-blue-100 text-blue-800
                    {% elseif booking.status == 'completed' %}bg-gray-100 text-gray-800
                    {% else %}bg-red-100 text-red-800{% endif %}">
                    {{ booking.status|title }}
                </span>
    </div>
            {% endfor %}
            
            {% if recentBookings|length == 0 %}
            <div class="text-center py-8 text-gray-500">
                <div class="text-4xl mb-2">📅</div>
                <div>No recent bookings</div>
    </div>
            {% endif %}
    </div>
</div>

    <!-- CUSTOMER SATISFACTION WIDGET -->
    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-100">
        <h3 class="text-lg font-semibold text-gray-800 mb-4">Customer Satisfaction</h3>
        <div class="space-y-4">
        <div class="flex items-center justify-between">
                <span class="text-sm text-gray-600">Overall Rating</span>
                <div class="flex items-center space-x-1">
                    <span class="text-yellow-400">⭐⭐⭐⭐⭐</span>
                    <span class="text-sm font-medium text-gray-800">4.8</span>
                </div>
            </div>
            
            <div class="space-y-2">
                <div class="flex justify-between text-sm">
                    <span class="text-gray-600">Food Quality</span>
                    <span class="font-medium text-gray-800">4.9</span>
                </div>
                <div class="w-full bg-gray-200 rounded-full h-2">
                    <div class="bg-green-500 h-2 rounded-full" style="width: 98%"></div>
                </div>
            </div>
            
            <div class="space-y-2">
                <div class="flex justify-between text-sm">
                    <span class="text-gray-600">Service</span>
                    <span class="font-medium text-gray-800">4.7</span>
                </div>
                <div class="w-full bg-gray-200 rounded-full h-2">
                    <div class="bg-green-500 h-2 rounded-full" style="width: 94%"></div>
                </div>
            </div>
            
            <div class="space-y-2">
                <div class="flex justify-between text-sm">
                    <span class="text-gray-600">Ambiance</span>
                    <span class="font-medium text-gray-800">4.8</span>
                </div>
                <div class="w-full bg-gray-200 rounded-full h-2">
                    <div class="bg-green-500 h-2 rounded-full" style="width: 96%"></div>
                </div>
            </div>
            
            <div class="pt-2 border-t border-gray-100">
                <div class="text-center">
                    <div class="text-2xl font-bold text-gray-800">127</div>
                    <div class="text-sm text-gray-500">Reviews this month</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- QUICK ACTIONS AND ALERTS -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- QUICK ACTION WIDGETS -->
    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-100">
        <h3 class="text-lg font-semibold text-gray-800 mb-4">Quick Actions</h3>
        <div class="grid grid-cols-2 gap-3">
            <a href="{{ path('app_bookings_new') }}" class="flex items-center justify-center space-x-2 p-3 bg-[#235A2F] text-white rounded-lg hover:bg-green-700 transition-colors">
                <span>📅</span>
