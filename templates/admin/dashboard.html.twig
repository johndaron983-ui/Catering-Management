            <div class="flex items-start space-x-3 p-3 bg-blue-50 rounded-lg">
                <span class="text-blue-500 text-lg">📈</span>
                <div>
                    <div class="font-medium text-blue-800">Performance Update</div>
                    <div class="text-sm text-blue-600">Revenue increased by 18.2% this month</div>
            </div>
        </div>
    </div>
