            </a>
        </div>
    </div>

    <!-- SYSTEM ALERTS WIDGET -->
    <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-100">
        <h3 class="text-lg font-semibold text-gray-800 mb-4">System Alerts</h3>
        <div class="space-y-3">
            <div class="flex items-start space-x-3 p-3 bg-red-50 rounded-lg">
                <span class="text-red-500 text-lg">⚠️</span>
                <div>
                    <div class="font-medium text-red-800">Low Inventory Alert</div>
                    <div class="text-sm text-red-600">Chicken breast stock is running low (15% remaining)</div>
                </div>
        </div>
            
            <div class="flex items-start space-x-3 p-3 bg-yellow-50 rounded-lg">
                <span class="text-yellow-500 text-lg">📬</span>
                <div>
                    <div class="font-medium text-yellow-800">New Booking Requests</div>
                    <div id="system-alert-pending-text" class="text-sm text-yellow-600">{{ pendingRequests }} pending booking request{{ pendingRequests == 1 ? '' : 's' }} require your attention</div>
