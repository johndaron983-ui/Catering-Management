{% extends 'admin/layout.html.twig' %}

{% block admin_body %}
<div class="container mx-auto px-4 py-6">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-3xl font-bold text-gray-800">User Management</h1>
        <a href="{{ path('app_user_new') }}" class="bg-green-500 text-white py-2 px-4 rounded-lg hover:bg-green-600 transition-colors flex items-center gap-2">
            + Create New User
        </a>
    </div>

    <!-- INSTANT FILTERS -->
    <div class="bg-white rounded-lg shadow-sm p-4 border border-gray-100 mb-6">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Search Users</label>
                <input type="text" id="search-email" placeholder="Search by email..." 
                       class="w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#235A2F]">
            </div>
            
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Role</label>
                <select id="filter-role" class="w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#235A2F]">
                    <option value="">All Roles</option>
                    <option value="Admin">Admin</option>
                    <option value="Staff">Staff</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                <select id="filter-status" class="w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#235A2F]">
                    <option value="">All Status</option>
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                </select>
            </div>

            <div>
                <button id="clear-filters" class="w-full bg-gray-500 text-white px-4 py-2 rounded-md hover:bg-gray-600 transition-colors">
                    Clear Filters
                </button>
            </div>
        </div>
    </div>

    {% if totalUsers == 0 %}
    <div class="bg-blue-100 border border-blue-400 text-blue-700 px-4 py-3 rounded">
        No users found. <a href="{{ path('app_user_new') }}" class="underline">Create the first user</a>.
    </div>
    {% else %}
    <div class="bg-white rounded-lg shadow-sm overflow-hidden">
        <table id="users-table" class="w-full">
            <thead class="bg-gray-100 border-b">
                <tr>
                    <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Username</th>
                    <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Email</th>
                    <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Role</th>
                    <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Status</th>
                    <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Created</th>
                    <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                <tr class="border-b hover:bg-gray-50" data-record-id="{{ user.id }}">
                    <td class="px-6 py-4 text-sm font-medium text-gray-900">{{ user.username }}</td>
                    <td class="px-6 py-4 text-sm text-gray-600">{{ user.email }}</td>
                    <td class="px-6 py-4 text-sm">
                        {% for role in user.roles %}
                            {% if role != 'ROLE_USER' %}
                            <span class="inline-block bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded mr-1">
                                {{ role == 'ROLE_ADMIN' ? 'Admin' : 'Staff' }}
                            </span>
                            {% endif %}
                        {% endfor %}
                    </td>
                    <td class="px-6 py-4 text-sm">
                        <span class="inline-block {% if user.status == 'active' %}bg-green-100 text-green-800{% else %}bg-red-100 text-red-800{% endif %} text-xs px-2 py-1 rounded">
                            {{ user.status|capitalize }}
                        </span>
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-600">
                        {{ user.createdAt ? user.createdAt|date('Y-m-d H:i') : 'N/A' }}
                    </td>
                    <td class="px-6 py-4 text-sm space-x-2">
                        <a href="{{ path('app_user_show', {'id': user.id}) }}" class="text-blue-600 hover:text-blue-800">View</a>
                        <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="text-yellow-600 hover:text-yellow-800">Edit</a>
                        
                        <form method="POST" action="{{ path('app_user_status', {'id': user.id}) }}" style="display: inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('status' ~ user.id) }}" />
                            <button type="submit" class="text-{% if user.status == 'active' %}red{% else %}green{% endif %}-600 hover:text-{% if user.status == 'active' %}red{% else %}green{% endif %}-800">
                                {{ user.status == 'active' ? 'Disable' : 'Enable' }}
                            </button>
                        </form>

                        <form method="POST" action="{{ path('app_user_delete', {'id': user.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this user?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}" />
                            <button type="submit" class="text-red-600 hover:text-red-800">Delete</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="mt-4 text-sm text-gray-600">
        Total Users: <strong id="users-total-count">{{ totalUsers }}</strong>
    </div>
    {% endif %}
</div>

<!-- DataTables CSS and JS -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/jquery.dataTables.min.css">
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>

<script>
function initializeUsersTable() {
    // Destroy existing DataTable instance if it exists
    if ($.fn.DataTable.isDataTable('#users-table')) {
        $('#users-table').DataTable().destroy();
    }

    const table = $('#users-table').DataTable({
        responsive: true,
        pageLength: 25,
        lengthChange: true,
        searching: true,
        ordering: true,
        info: true,
        paging: true,
        dom: '<"top"lf>rt<"bottom"ip>'
    });

    // Column indices: Email at 1, Role at 2, Status at 3
    const COL_EMAIL = 1;
    const COL_ROLE = 2;
    const COL_STATUS = 3;

    // Filter by Role dropdown
    $('#filter-role').off('change').on('change', function() {
        table.column(COL_ROLE).search(this.value).draw();
    });

    // Filter by Status dropdown
    $('#filter-status').off('change').on('change', function() {
        table.column(COL_STATUS).search(this.value).draw();
    });

    // Search by Email with debouncing
    let searchTimeout;
    $('#search-email').off('keyup').on('keyup', function() {
        clearTimeout(searchTimeout);
        const searchValue = this.value;
        searchTimeout = setTimeout(() => {
            table.column(COL_EMAIL).search(searchValue).draw();
        }, 300);
    });

    // Clear all filters
    $('#clear-filters').off('click').on('click', function(e) {
        e.preventDefault();
        
        $('#filter-role').val('').trigger('change');
        $('#filter-status').val('').trigger('change');
        $('#search-email').val('');
        
        table.search('').columns().search('').draw();
    });
}

// Initialize on page load and Turbo navigation
document.addEventListener('DOMContentLoaded', initializeUsersTable);
document.addEventListener('turbo:load', initializeUsersTable);
document.addEventListener('turbo:render', initializeUsersTable);
</script>
{% set realtime_module = 'users' %}
{% set realtime_table_selector = '#users-table' %}
{% set realtime_reinit_fn = 'initializeUsersTable' %}
{% set realtime_query_params = { 'page': app.request.query.getInt('page', 1) } %}
{% include 'admin/_module_realtime.html.twig' %}
{% endblock %}
