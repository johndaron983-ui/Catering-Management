{% for user in users %}
<tr class="border-b hover:bg-gray-50" data-record-id="{{ user.id }}">
    <td class="px-6 py-4 text-sm font-medium text-gray-900">{{ user.username }}</td>
    <td class="px-6 py-4 text-sm text-gray-600">{{ user.email }}</td>
    <td class="px-6 py-4 text-sm">
        {% for role in user.roles %}
            {% if role != 'ROLE_USER' %}
            <span class="inline-block bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded mr-1">
                {{ role == 'ROLE_ADMIN' ? 'Admin' : 'Staff' }}
            </span>
            {% endif %}
        {% endfor %}
    </td>
    <td class="px-6 py-4 text-sm">
        <span class="inline-block {% if user.status == 'active' %}bg-green-100 text-green-800{% else %}bg-red-100 text-red-800{% endif %} text-xs px-2 py-1 rounded">
            {{ user.status|capitalize }}
        </span>
    </td>
    <td class="px-6 py-4 text-sm text-gray-600">
        {{ user.createdAt ? user.createdAt|date('Y-m-d H:i') : 'N/A' }}
    </td>
    <td class="px-6 py-4 text-sm space-x-2">
        <a href="{{ path('app_user_show', {'id': user.id}) }}" class="text-blue-600 hover:text-blue-800">View</a>
        <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="text-yellow-600 hover:text-yellow-800">Edit</a>
        <form method="POST" action="{{ path('app_user_status', {'id': user.id}) }}" style="display: inline;">
            <input type="hidden" name="_token" value="{{ csrf_token('status' ~ user.id) }}" />
            <button type="submit" class="text-{% if user.status == 'active' %}red{% else %}green{% endif %}-600 hover:text-{% if user.status == 'active' %}red{% else %}green{% endif %}-800">
                {{ user.status == 'active' ? 'Disable' : 'Enable' }}
            </button>
        </form>
        <form method="POST" action="{{ path('app_user_delete', {'id': user.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this user?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}" />
            <button type="submit" class="text-red-600 hover:text-red-800">Delete</button>
        </form>
    </td>
</tr>
{% else %}
<tr data-empty-row="1">
    <td colspan="6" class="px-6 py-8 text-center text-gray-500">No users found.</td>
</tr>
{% endfor %}
