{% for log in logs %}
<tr class="hover:bg-gray-50 transition" data-record-id="{{ log.id }}" data-log-timestamp="{{ log.createdAt|date('U') }}">
    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
        {{ log.createdAt|date('Y-m-d H:i:s') }}
    </td>
    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
        <span class="font-medium">{{ log.username }}</span>
    </td>
    <td class="px-6 py-4 whitespace-nowrap text-sm">
        <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full
            {% if 'ADMIN' in log.role %}bg-red-100 text-red-800
            {% elseif 'STAFF' in log.role %}bg-blue-100 text-blue-800
            {% else %}bg-gray-100 text-gray-800{% endif %}">
            {{ log.role }}
        </span>
    </td>
    <td class="px-6 py-4 whitespace-nowrap text-sm">
        <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full
            {% if log.action == 'CREATE' %}bg-green-100 text-green-800
            {% elseif log.action == 'UPDATE' %}bg-blue-100 text-blue-800
            {% elseif log.action == 'DELETE' %}bg-red-100 text-red-800
            {% elseif log.action == 'LOGIN' %}bg-purple-100 text-purple-800
            {% elseif log.action == 'LOGOUT' %}bg-gray-100 text-gray-800
            {% else %}bg-yellow-100 text-yellow-800{% endif %}">
            {{ log.action }}
        </span>
    </td>
    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
        {% if log.recordType %}
            <span class="bg-gray-100 text-gray-700 px-2 py-1 rounded text-xs font-medium">{{ log.recordType }}</span>
        {% else %}
            <span class="text-gray-400">-</span>
        {% endif %}
    </td>
    <td class="px-6 py-4 text-sm text-gray-600 max-w-xs truncate">
        {{ log.targetData|default('-') }}
    </td>
    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
        <a href="{{ path('app_activity_logs_show', {'id': log.id}) }}" class="text-[#235A2F] hover:text-[#1a4a26]">View</a>
        {% if log.recordType and log.recordId %}
            <span class="text-gray-300 mx-2">|</span>
            <a href="{{ path('app_activity_logs_by_record', {'recordType': log.recordType, 'recordId': log.recordId}) }}" class="text-[#235A2F] hover:text-[#1a4a26]">Record History</a>
        {% endif %}
    </td>
</tr>
{% else %}
<tr data-empty-row="1">
    <td colspan="7" class="px-6 py-8 text-center text-gray-500">No activity logs found.</td>
</tr>
{% endfor %}
