{# Enable admin module realtime polling. Set realtime_module and optional realtime_reinit_fn in the child template. #}
{% if realtime_module is defined %}
<script>
window.__ADMIN_MODULE_REALTIME__ = {
    module: {{ realtime_module|json_encode|raw }},
    pollUrl: {{ path('app_admin_realtime_module', { module: realtime_module })|json_encode|raw }},
    tableSelector: {{ (realtime_table_selector|default('#module-table'))|json_encode|raw }},
    reinitTable: {{ (realtime_reinit_fn|default(null))|json_encode|raw }},
    queryParams: {{ (realtime_query_params|default({}))|json_encode|raw }}
};
</script>
<script src="{{ asset('js/admin-module-realtime.js') }}" defer></script>
{% endif %}
