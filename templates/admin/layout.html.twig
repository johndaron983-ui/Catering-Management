{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 flex">
   
    <aside id="admin-sidebar" class="w-72 shrink-0 bg-[#235A2F] text-white transition-all duration-300 hidden md:block fixed left-0 top-0 h-full z-20">
        <div class="flex items-center gap-3 px-5 h-16 border-b border-white/10">
            <img alt="Every Event Logo" class="h-9 w-9 rounded object-contain"
                 src="{{ asset('image/2.png') }}" />
            <span class="font-bold tracking-wide">Every Event</span>
        </div>
        <nav class="p-3">
            {% if 'ROLE_ADMIN' in app.user.roles %}
            <a href="{{ path('app_admin_dashboard') }}" class="group flex items-center gap-3 px-3 py-2 rounded-md hover:bg-white/10 {{ app.current_route starts with 'app_admin' ? 'bg-white/10' : '' }}">
                <span>📊</span>
                <span>Dashboard</span>
            </a>
            {% endif %}
            <a href="{{ path('app_bookings_index') }}" class="group flex items-center gap-3 px-3 py-2 rounded-md hover:bg-white/10 {{ app.current_route starts with 'app_bookings' ? 'bg-white/10' : '' }}">
                <span>📅</span>
                <span>Bookings</span>
                <span class="ml-auto text-xs bg-[#ED1C24] text-white px-2 py-0.5 rounded-full">5</span>
            </a>
            <a href="{{ path('app_services_index') }}" class="group flex items-center gap-3 px-3 py-2 rounded-md hover:bg-white/10">
                <span>🍽️</span>
                <span>Services</span>
            </a>
            <a href="{{ path('app_inventory_index') }}" class="group flex items-center gap-3 px-3 py-2 rounded-md hover:bg-white/10 {{ app.current_route starts with 'app_inventory' ? 'bg-white/10' : '' }}">
                <span>📦</span>
                <span>Inventory</span>
                <span class="ml-auto text-xs bg-[#ED1C24] text-white px-2 py-0.5 rounded-full">2</span>
            </a>
            <a href="{{ path('app_product_index') }}" class="group flex items-center gap-3 px-3 py-2 rounded-md hover:bg-white/10 {{ app.current_route starts with 'app_product' ? 'bg-white/10' : '' }}">
                <span>🛒</span>
                <span>Products</span>
            </a>
            <a href="{{ path('app_supplier_index') }}" class="group flex items-center gap-3 px-3 py-2 rounded-md hover:bg-white/10 {{ app.current_route starts with 'app_supplier' ? 'bg-white/10' : '' }}">
                <span>🏷️</span>
                <span>Suppliers</span>
            </a>
            {% if 'ROLE_ADMIN' in app.user.roles %}
            <a href="{{ path('app_admin_dashboard') }}" class="group flex items-center gap-3 px-3 py-2 rounded-md hover:bg-white/10 {{ app.current_route starts with 'app_admin' ? 'bg-white/10' : '' }}">
                <span>📈</span>
                <span>Analytics</span>
            </a>
            <a href="{{ path('app_user_index') }}" class="group flex items-center gap-3 px-3 py-2 rounded-md hover:bg-white/10">
                <span>🧑‍🍳</span>
                <span>Users</span>
            </a>
            <a href="{{ path('app_activity_logs_index') }}" class="group flex items-center gap-3 px-3 py-2 rounded-md hover:bg-white/10 {{ app.current_route starts with 'app_activity_logs' ? 'bg-white/10' : '' }}">
                <span>📋</span>
                <span>Activity Logs</span>
            </a>
            {% endif %}
            <a href="{{path('app_profile_show')}}" class="group flex items-center gap-3 px-3 py-2 rounded-md hover:bg-white/10">
                <span>👤</span>
                <span>Profile</span>
            </a>
            <form id="logout-form" action="{{ path('app_logout') }}" method="post" class="mt-2">
                <button type="submit" class="w-full text-left group flex items-center gap-3 px-3 py-2 rounded-md hover:bg-white/10">
                    <span>🚪</span>
                    <span>Logout</span>
                </button>
            </form>
        </nav>
    </aside>

    {# Main #}
    <div class="flex-1 min-w-0 md:ml-72">
        <header class="sticky top-0 z-10 h-16 bg-white/90 backdrop-blur border-b border-gray-100 flex items-center px-4 md:px-6 justify-between">
            <div class="flex items-center gap-2">
                <button id="sidebar-toggle" class="md:hidden inline-flex h-9 w-9 items-center justify-center rounded bg-[#235A2F] text-white">☰</button>
                <div class="text-gray-700 hidden sm:block font-semi-bold">Hello! </div>
                <div class="text-black-700 hidden sm:block font-bold">
                {% if app.user and 'ROLE_ADMIN' in app.user.roles %}
                    Admin
                {% elseif app.user and 'ROLE_STAFF' in app.user.roles %}
                    Staff
                {% else %}
                    User
                {% endif %}
                </div>
            </div>
            <div class="flex items-center gap-3">
                <button class="relative h-9 w-9 rounded-full bg-gray-100">🔔</button>
                <img src="
                {% if app.user and 'ROLE_ADMIN' in app.user.roles %}
                    {{ asset('image/admin1.jpg') }}
                {% elseif app.user and 'ROLE_STAFF' in app.user.roles %}
                    {{ asset('image/staff.png') }}
                {% else %}
                    {{ asset('image/default-avatar.png') }}
                {% endif %}   
                " alt="User Profile" class="h-9 w-9 rounded-full object-cover" /> 
                <div class="text-gray-700 hidden sm:block font-bold">
                {% if app.user and 'ROLE_ADMIN' in app.user.roles %}
                    John Rio
                {% elseif app.user and 'ROLE_STAFF' in app.user.roles %}
                    Staff
                {% else %}
                    User
                {% endif %}
                 
            </div>
        </header>

        <main class="p-4 md:p-6">
            {% block admin_body %}{% endblock %}
        </main>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const toggle = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('admin-sidebar');
    if (toggle && sidebar) {
        toggle.addEventListener('click', function () {
            sidebar.classList.toggle('hidden');
            // Add overlay for mobile
            if (!sidebar.classList.contains('hidden')) {
                const overlay = document.createElement('div');
                overlay.id = 'sidebar-overlay';
                overlay.className = 'fixed inset-0 bg-black bg-opacity-50 z-10 md:hidden';
                overlay.addEventListener('click', function() {
                    sidebar.classList.add('hidden');
                    overlay.remove();
                });
                document.body.appendChild(overlay);
            } else {
                const overlay = document.getElementById('sidebar-overlay');
                if (overlay) overlay.remove();
            }
        });
    }
});
</script>
{% endblock %}


