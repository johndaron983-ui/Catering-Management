{{ form_start(form, { attr: { class: 'space-y-4' } }) }}
    <div class="grid grid-cols-1 gap-4">
        <div>
            {{ form_label(form.name, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
            {{ form_widget(form.name, {'attr': {'class': 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#235A2F] focus:ring-[#235A2F]'}}) }}
            {{ form_errors(form.name) }}
        </div>
        <div>
            {{ form_label(form.description, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
            {{ form_widget(form.description, {'attr': {'class': 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#235A2F] focus:ring-[#235A2F]'}}) }}
            {{ form_errors(form.description) }}
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                {{ form_label(form.eventType, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                {{ form_widget(form.eventType, {'attr': {'class': 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#235A2F] focus:ring-[#235A2F]'}}) }}
                {{ form_errors(form.eventType) }}
            </div>
            <div>
                {{ form_label(form.basePrice, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                {{ form_widget(form.basePrice, {'attr': {'class': 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#235A2F] focus:ring-[#235A2F]'}}) }}
                {{ form_errors(form.basePrice) }}
            </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                {{ form_label(form.minGuests, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                {{ form_widget(form.minGuests, {'attr': {'class': 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#235A2F] focus:ring-[#235A2F]'}}) }}
                {{ form_errors(form.minGuests) }}
            </div>
            <div>
                {{ form_label(form.maxGuests, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                {{ form_widget(form.maxGuests, {'attr': {'class': 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#235A2F] focus:ring-[#235A2F]'}}) }}
                {{ form_errors(form.maxGuests) }}
            </div>
        </div>

        <div>
            {{ form_label(form.image, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
            {{ form_widget(form.image, {'attr': {'class': 'mt-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-[#235A2F] file:text-white hover:file:bg-[#1a4a26]'}}) }}
            {{ form_errors(form.image) }}
            {% if service.image %}
                <div class="mt-2">
                    <p class="text-sm text-gray-600">Current image:</p>
                    <img src="{{ asset('image/' ~ service.image) }}" alt="Service image" class="mt-1 h-20 w-20 object-cover rounded-md">
                </div>
            {% endif %}
        </div>
    </div>
    <div class="pt-2">
        <button class="inline-flex items-center rounded-md bg-[#235A2F] px-4 py-2 text-white hover:opacity-90">{{ button_label|default('Save') }}</button>
    </div>
{{ form_end(form) }}
