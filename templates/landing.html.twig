{% extends "landing_layout.html.twig" %}

{% block title %}Every Event | Premium Catering & Events{% endblock %}

{% block styles %}
<style>
    .fade-in-up { animation: fadeInUp 0.8s ease-out; }
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    .image-hover-zoom { overflow: hidden; position: relative; }
    .image-hover-zoom img { transition: transform 0.6s ease; }
    .image-hover-zoom:hover img { transform: scale(1.08); }
    .service-card { transition: all 0.4s ease; }
    .service-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(0,0,0,0.1); }
    .menu-item { position: relative; overflow: hidden; aspect-ratio: 1; }
    .menu-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
    .menu-item:hover img { transform: scale(1.15); }
    .menu-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.6); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.4s ease; }
    .menu-item:hover .menu-overlay { opacity: 1; }
    .cta-button { background-color: #d97066; transition: all 0.3s ease; display: inline-block; padding: 12px 32px; border-radius: 6px; color: white; font-weight: 500; text-decoration: none; border: none; font-size: 16px; }
    .cta-button:hover { background-color: #c85d54; transform: translateY(-2px); box-shadow: 0 8px 16px rgba(217,112,102,0.3); }
    .nav-link { position: relative; transition: color 0.3s ease; }
    .nav-link.active, .nav-link:hover { color: #d97066; }
    section { scroll-margin-top: 80px; }
</style>
{% endblock %}

{% block body %}
<nav class="fixed top-0 left-0 right-0 bg-white shadow-sm z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-20">
            <a href="#home" class="text-2xl font-bold serif-heading text-gray-900">Every Event</a>
            <div class="hidden md:flex items-center gap-8">
                <a href="#home" class="nav-link active text-gray-700 hover:text-red-400 text-sm font-medium">Home</a>
                <a href="#about" class="nav-link text-gray-700 hover:text-red-400 text-sm font-medium">About</a>
                <a href="#services" class="nav-link text-gray-700 hover:text-red-400 text-sm font-medium">Services</a>
                <a href="#menu" class="nav-link text-gray-700 hover:text-red-400 text-sm font-medium">Menus</a>
                <a href="#contact" class="nav-link text-gray-700 hover:text-red-400 text-sm font-medium">Contact</a>
                <a href="#gallery" class="nav-link text-gray-700 hover:text-red-400 text-sm font-medium">Gallery</a>
            </div>
        </div>
    </div>
</nav>

<section id="home" class="pt-32 pb-0 bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div class="fade-in-up">
                <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-6 leading-tight">Every Event<br> A Taste of Every <br>Occasion</h1>
                <p class="text-lg text-gray-600 mb-8 leading-relaxed">Every Event offers an elegant fine dining experience, blending Filipino flavors with modern culinary techniques.</p>
                <a href="#menu" class="cta-button">Our Menu</a>
            </div>
            <div class="image-hover-zoom h-96 lg:h-screen relative">
                <img src="/images/image.png" alt="Fine Dining Catering Setup" class="w-full h-full object-cover rounded-lg">
            </div>
        </div>
    </div>
</section>

<section id="about" class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div class="image-hover-zoom h-96 lg:h-full order-2 lg:order-1">
                <img src="/images/aboutUS.png" alt="Catering Table Setup" class="w-full h-full object-cover rounded-lg">
            </div>
            <div class="fade-in-up order-1 lg:order-2">
                <h2 class="text-5xl font-bold text-gray-900 mb-6 leading-tight">About Us</h2>
                <p class="text-base text-gray-600 mb-4 leading-relaxed">Every Event brings an elegant fine dining experience with a Filipino touch.</p>
                <a href="#menu" class="cta-button">Our Menu</a>
            </div>
        </div>
    </div>
</section>

<section id="services" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16 fade-in-up">
            <h2 class="text-5xl font-bold text-gray-900 mb-4">Our Services</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="service-card bg-gray-50 p-8 rounded-lg fade-in-up">
                <h3 class="text-2xl font-bold text-gray-900 mb-3">Weddings</h3>
                <p class="text-gray-600">Create unforgettable moments with premium wedding catering.</p>
            </div>
            <div class="service-card bg-gray-50 p-8 rounded-lg fade-in-up">
                <h3 class="text-2xl font-bold text-gray-900 mb-3">Corporate Events</h3>
                <p class="text-gray-600">Professional catering for conferences and celebrations.</p>
            </div>
            <div class="service-card bg-gray-50 p-8 rounded-lg fade-in-up">
                <h3 class="text-2xl font-bold text-gray-900 mb-3">Private Parties</h3>
                <p class="text-gray-600">Intimate celebrations with personalized menus.</p>
            </div>
        </div>
    </div>
</section>

<footer class="bg-gray-900 text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
            <div>
                <h3 class="text-2xl font-bold serif-heading mb-2">Every Event</h3>
                <p class="text-gray-400 text-sm">A taste of every occasion</p>
            </div>
            <div>
                <h4 class="font-semibold mb-4">Quick Links</h4>
                <ul class="space-y-2 text-sm text-gray-400">
                    <li><a href="#home" class="hover:text-white transition">Home</a></li>
                    <li><a href="#about" class="hover:text-white transition">About</a></li>
                    <li><a href="#services" class="hover:text-white transition">Services</a></li>
                </ul>
            </div>
        </div>
        <div class="border-t border-gray-700 pt-8">
            <p class="text-gray-400 text-sm">&copy; 2026 Every Event Catering Services. All rights reserved.</p>
        </div>
    </div>
</footer>
{% endblock %}

{% block scripts %}
<script>
    document.querySelectorAll("a[href^='#']").forEach(anchor => {
        anchor.addEventListener("click", function (e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute("href"));
            if (target) {
                target.scrollIntoView({ behavior: "smooth", block: "start" });
            }
        });
    });
</script>
{% endblock %}
