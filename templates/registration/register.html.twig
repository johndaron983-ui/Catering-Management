{% extends 'base.html.twig' %}

{% block title %}Register - Every Event | Premium Catering & Events{% endblock %}

{% block body %}
    <!-- ========== AUTH SECTION ========== -->
    <section class="min-h-screen bg-brand-cream relative overflow-hidden flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
        <!-- Decorative Blobs -->
        <div class="decoration-blob w-[500px] h-[500px] -top-48 -right-48 opacity-20"></div>
        <div class="decoration-blob w-[400px] h-[400px] -bottom-32 -left-32 opacity-15"></div>
        
        <div class="w-full max-w-5xl relative z-10">
            <div class="bg-white rounded-3xl shadow-2xl overflow-hidden">
                <div class="grid grid-cols-1 lg:grid-cols-2">
                    <!-- Left Side - Image -->
                    <div class="hidden lg:block relative">
                        <img src="{{ asset('image/catering-buffet-68ef0e79c166e.jpg') }}" alt="Catering Event" class="absolute inset-0 w-full h-full object-cover">
                        <div class="absolute inset-0 bg-gradient-to-br from-brand-charcoal/80 to-brand-charcoal/60"></div>
                        <div class="relative z-10 h-full flex flex-col justify-between p-12 text-white">
                            <div>
                                <a href="{{ path('app_home') }}" class="flex items-center gap-3">
                                    <img src="{{ asset('image/everyevent.png') }}" alt="Every Event Logo" class="h-10 w-auto object-contain">
                                    <span class="text-xl font-bold font-serif">Every Event</span>
                                </a>
                            </div>
                            <div>
                                <h2 class="text-4xl font-bold mb-4 font-serif">Join Every Event</h2>
                                <p class="text-gray-200 mb-6">Create an account to book catering services, track your orders, and manage your special events with ease.</p>
                                <div class="flex items-center gap-2 text-brand-gold">
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                </div>
                                <p class="text-sm text-gray-300 mt-2">Trusted by thousands of happy customers</p>
                            </div>
                            <div class="text-sm text-gray-400">
                                <p>&copy; 2026 Every Event. All rights reserved.</p>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Right Side - Form -->
                    <div class="p-8 lg:p-12">
                        <!-- Mobile Logo -->
                        <div class="lg:hidden text-center mb-8">
                            <a href="{{ path('app_home') }}" class="inline-flex items-center gap-3">
                                <img src="{{ asset('image/everyevent.png') }}" alt="Every Event Logo" class="h-10 w-auto object-contain">
                                <span class="text-xl font-bold font-serif text-brand-charcoal">Every Event</span>
                            </a>
                        </div>
                        
                        <div class="text-center mb-8">
                            <span class="inline-block px-3 py-1 bg-brand-gold/10 text-brand-gold text-xs font-semibold rounded-full mb-3">
                                
                            </span>
                            <h1 class="text-3xl font-bold text-brand-charcoal font-serif mb-2">Register</h1>
                            <p class="text-gray-600 text-sm">Create your account to get started</p>
                        </div>

                        {# Flash Messages #}
                        {% for label, messages in app.flashes %}
                            {% if label == 'danger' %}
                                <div class="mb-6 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl flex items-start gap-3">
                                    <i class="fas fa-exclamation-circle mt-0.5"></i>
                                    <div>
                                        {% for message in messages %}
                                            <p class="text-sm">{{ message }}</p>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% elseif label == 'success' %}
                                <div class="mb-6 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl flex items-start gap-3">
                                    <i class="fas fa-check-circle mt-0.5"></i>
                                    <div>
                                        {% for message in messages %}
                                            <p class="text-sm">{{ message }}</p>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% elseif label == 'warning' %}
                                <div class="mb-6 bg-yellow-50 border border-yellow-200 text-yellow-700 px-4 py-3 rounded-xl flex items-start gap-3">
                                    <i class="fas fa-exclamation-triangle mt-0.5"></i>
                                    <div>
                                        {% for message in messages %}
                                            <p class="text-sm">{{ message }}</p>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}

                        {% if registrationForm.vars.errors|length %}
                            <div class="mb-6 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl flex items-start gap-3">
                                <i class="fas fa-exclamation-circle mt-0.5"></i>
                                <div>
                                    {{ form_errors(registrationForm) }}
                                </div>
                            </div>
                        {% endif %}

                        {{ form_start(registrationForm, {'attr': {'class': 'space-y-5'}}) }}
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Username <span class="text-red-500">*</span></label>
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                        <i class="fas fa-user text-gray-400"></i>
                                    </div>
                                    {{ form_widget(registrationForm.username, {
                                        'attr': {
                                            'class': 'form-input pl-10',
                                            'placeholder': 'Enter your username'
                                        }
                                    }) }}
                                </div>
                                {{ form_errors(registrationForm.username) }}
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Email Address <span class="text-red-500">*</span></label>
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                        <i class="fas fa-envelope text-gray-400"></i>
                                    </div>
                                    {{ form_widget(registrationForm.email, {
                                        'attr': {
                                            'class': 'form-input pl-10',
                                            'placeholder': 'Enter your email',
                                            'autocomplete': 'email'
                                        }
                                    }) }}
                                </div>
                                {{ form_errors(registrationForm.email) }}
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Password <span class="text-red-500">*</span></label>
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                        <i class="fas fa-lock text-gray-400"></i>
                                    </div>
                                    {{ form_widget(registrationForm.plainPassword, {
                                        'attr': {
                                            'class': 'form-input pl-10',
                                            'placeholder': 'Create a strong password'
                                        }
                                    }) }}
                                </div>
                                {{ form_errors(registrationForm.plainPassword) }}
                            </div>

                            <div class="flex items-start">
                                {{ form_widget(registrationForm.agreeTerms, {
                                    'attr': {
                                        'class': 'h-4 w-4 mt-1 text-brand-gold focus:ring-brand-gold border-gray-300 rounded cursor-pointer'
                                    }
                                }) }}
                                <label class="ml-3 text-sm text-gray-600">
                                    I agree to the <a href="#" class="text-brand-gold hover:underline">Terms of Service</a> and <a href="#" class="text-brand-gold hover:underline">Privacy Policy</a>
                                </label>
                            </div>
                            {{ form_errors(registrationForm.agreeTerms) }}

                            <button type="submit" class="w-full btn-primary py-4 text-lg">
                                <i class="fas fa-user-plus mr-2"></i>Create Account
                            </button>
                        {{ form_end(registrationForm) }}
                        
                        <div class="mt-8 text-center">
                            <p class="text-gray-600 text-sm">
                                Already have an account? 
                                <a href="{{ path('app_login') }}" class="text-brand-gold font-semibold hover:underline">Sign in here</a>
                            </p>
                        </div>
                        
                        <div class="mt-6 pt-6 border-t border-gray-200 text-center lg:hidden">
                            <p class="text-sm text-gray-500">
                                &copy; 2026 Every Event. All rights reserved.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
