{% extends 'base.html.twig' %}

{% block title %}Login - Every Event | Premium Catering & Events{% endblock %}

{% block body %}
    <!-- ========== AUTH SECTION ========== -->
    <section class="min-h-screen bg-brand-cream relative overflow-hidden flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
        <!-- Decorative Blobs -->
        <div class="decoration-blob w-[500px] h-[500px] -top-48 -right-48 opacity-20"></div>
        <div class="decoration-blob w-[400px] h-[400px] -bottom-32 -left-32 opacity-15"></div>
        
        <div class="w-full max-w-5xl relative z-10">
            <div class="bg-white rounded-3xl shadow-2xl overflow-hidden">
                <div class="grid grid-cols-1 lg:grid-cols-2">
                    <!-- Left Side - Image -->
                    <div class="hidden lg:block relative">
                        <img src="{{ asset('image/catering-buffet-68ef0e79c166e.jpg') }}" alt="Catering Event" class="absolute inset-0 w-full h-full object-cover">
                        <div class="absolute inset-0 bg-gradient-to-br from-brand-charcoal/80 to-brand-charcoal/60"></div>
                        <div class="relative z-10 h-full flex flex-col justify-between p-12 text-white">
                            <div>
                                <a href="{{ path('app_home') }}" class="flex items-center gap-3">
                                    <img src="{{ asset('image/everyevent.png') }}" alt="Every Event Logo" class="h-10 w-auto object-contain">
                                    <span class="text-xl font-bold font-serif">Every Event</span>
                                </a>
                            </div>
                            <div>
                                <h2 class="text-4xl font-bold mb-4 font-serif">Welcome Back</h2>
                                <p class="text-gray-200 mb-6">Sign in to manage your bookings, explore our services, and plan your next memorable event with us.</p>
                                <div class="flex items-center gap-2 text-brand-gold">
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                </div>
                                <p class="text-sm text-gray-300 mt-2">Trusted by thousands of happy customers</p>
                            </div>
                            <div class="text-sm text-gray-400">
                                <p>&copy; 2026 Every Event. All rights reserved.</p>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Right Side - Form -->
                    <div class="p-8 lg:p-12">
                        <!-- Mobile Logo -->
                        <div class="lg:hidden text-center mb-8">
                            <a href="{{ path('app_home') }}" class="inline-flex items-center gap-3">
                                <img src="{{ asset('image/everyevent.png') }}" alt="Every Event Logo" class="h-10 w-auto object-contain">
                                <span class="text-xl font-bold font-serif text-brand-charcoal">Every Event</span>
                            </a>
                        </div>
                        
                        <div class="text-center mb-8">
                            <span class="inline-block px-3 py-1 bg-brand-gold/10 text-brand-gold text-xs font-semibold rounded-full mb-3">
                                
                            </span>
                            <h1 class="text-3xl font-bold text-brand-charcoal font-serif mb-2">Sign In</h1>
                            <p class="text-gray-600 text-sm">Access your account to continue</p>
                        </div>

                        {# Logged in note #}
                        {% if app.user %}
                            <div class="mb-6 bg-blue-50 border border-blue-200 text-blue-700 px-4 py-3 rounded-xl flex items-start gap-3">
                                <i class="fas fa-info-circle mt-0.5"></i>
                                <div>
                                    <p class="text-sm">You are logged in as <strong>{{ app.user.userIdentifier }}</strong>.</p>
                                    <a href="{{ path('app_logout') }}" class="text-brand-gold font-semibold hover:underline text-sm">Logout</a>
                                </div>
                            </div>
                        {% endif %}

                        {# Error message #}
                        {% if error %}
                            <div class="mb-6 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl flex items-start gap-3">
                                <i class="fas fa-exclamation-circle mt-0.5"></i>
                                <div>
                                    <p class="text-sm">{{ error.messageKey|trans(error.messageData, 'security') }}</p>
                                </div>
                            </div>
                        {% endif %}

                        <form method="post" novalidate class="space-y-5">
                            <div>
                                <label for="inputUsername" class="block text-sm font-medium text-gray-700 mb-2">Email or Username <span class="text-red-500">*</span></label>
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                        <i class="fas fa-envelope text-gray-400"></i>
                                    </div>
                                    <input type="text" value="{{ last_username }}" name="username" id="inputUsername" autocomplete="username" required autofocus class="form-input pl-10" placeholder="Enter your email or username">
                                </div>
                            </div>

                            <div>
                                <label for="inputPassword" class="block text-sm font-medium text-gray-700 mb-2">Password <span class="text-red-500">*</span></label>
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                        <i class="fas fa-lock text-gray-400"></i>
                                    </div>
                                    <input type="password" name="password" id="inputPassword" autocomplete="current-password" required class="form-input pl-10" placeholder="Enter your password">
                                </div>
                            </div>

                            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                            <div class="flex items-center justify-between">
                                <div class="flex items-center">
                                    <input type="checkbox" id="remember_me" name="_remember_me" class="h-4 w-4 text-brand-gold focus:ring-brand-gold border-gray-300 rounded cursor-pointer">
                                    <label for="remember_me" class="ml-2 text-sm text-gray-600 cursor-pointer">Remember me</label>
                                </div>
                                <a href="#" class="text-sm text-brand-gold font-semibold hover:underline">Forgot password?</a>
                            </div>

                            <button type="submit" class="w-full btn-primary py-4 text-lg">
                                <i class="fas fa-sign-in-alt mr-2"></i>Sign In
                            </button>
                        </form>
                        
                        <div class="mt-6">
                            <div class="relative">
                                <div class="absolute inset-0 flex items-center">
                                    <div class="w-full border-t border-gray-200"></div>
                                </div>
                                <div class="relative flex justify-center text-sm">
                                    <span class="px-2 bg-white text-gray-500">Or continue with</span>
                                </div>
                            </div>
                            
                            <a href="{{ path('connect_google_start') }}" class="mt-4 w-full flex items-center justify-center gap-3 px-4 py-3 border border-gray-300 rounded-xl bg-white text-gray-700 font-semibold hover:bg-gray-50 transition-colors">
                                <svg class="w-5 h-5" viewBox="0 0 24 24">
                                    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                                    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                                    <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                                    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                                </svg>
                                Sign in with Google
                            </a>
                        </div>
                        
                        <div class="mt-8 text-center">
                            <p class="text-gray-600 text-sm">
                                Don't have an account? 
                                <a href="{{ path('app_register') }}" class="text-brand-gold font-semibold hover:underline">Create one here</a>
                            </p>
                        </div>
                        
                        <div class="mt-6 pt-6 border-t border-gray-200 text-center lg:hidden">
                            <p class="text-sm text-gray-500">
                                &copy; 2026 Every Event. All rights reserved.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}

