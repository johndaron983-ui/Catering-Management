{% extends "base.html.twig" %}

{% block title %}About Us - Every Event | Premium Catering & Events{% endblock %}

{% block body %}
    <!-- ========== HERO SECTION ========== -->
    <section class="relative h-[500px] bg-brand-charcoal overflow-hidden">
        <div class="absolute inset-0">
            <img src="/images/aboutUs.png" alt="Catering Table Setup" class="w-full h-full object-cover">
            <div class="absolute inset-0 bg-gradient-to-r from-brand-charcoal/90 via-brand-charcoal/70 to-transparent"></div>
        </div>
        
        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-full flex items-center">
            <div class="max-w-2xl scroll-animate">
                <span class="inline-block px-4 py-2 bg-brand-gold/20 text-brand-gold text-sm font-semibold rounded-full mb-4">
                    Welcome to Every Event
                </span>
                <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
                    About Us
                </h1>
                <p class="text-xl text-gray-300 leading-relaxed">
                    Discover the passion and people behind Every Event's premium catering experiences.
                </p>
            </div>
        </div>

        <!-- Wave Separator -->
        <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none">
            <svg class="relative block w-full h-[60px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
                <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" class="fill-brand-cream"></path>
            </svg>
        </div>
    </section>
    
    <!-- ========== OUR STORY SECTION ========== -->
    <section class="py-24 bg-brand-cream relative overflow-hidden">
        <div class="decoration-blob w-96 h-96 -top-48 -right-48 opacity-30"></div>
        <div class="decoration-blob w-64 h-64 -bottom-32 -left-32 opacity-20"></div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <!-- Left Image -->
                <div class="scroll-animate-left relative">
                    <div class="relative">
                        <div class="absolute -inset-4 bg-gradient-to-br from-brand-gold/20 to-brand-orange/20 rounded-3xl blur-xl"></div>
                        <img src="/images/corporate.jpg" alt="Catering Event" class="relative w-full h-[500px] object-cover rounded-3xl shadow-2xl">
                    </div>
                </div>
                
                <!-- Right Content -->
                <div class="scroll-animate-right">
                    <span class="text-brand-gold font-semibold tracking-wider uppercase text-sm mb-2 block">Our Story</span>
                    <h2 class="text-4xl md:text-5xl font-bold text-brand-charcoal mb-6 leading-tight">
                        Fine Dining with<br>Every Event
                    </h2>
                    <div class="w-20 h-1 bg-gradient-to-r from-brand-gold to-brand-orange mb-8 rounded-full"></div>
                    <p class="text-lg text-gray-600 mb-4 leading-relaxed">
                        <span class="font-semibold text-brand-charcoal">Premium Catering Experience</span>
                    </p>
                    <p class="text-base text-gray-600 mb-4 leading-relaxed">
                        Every Event brings an elegant fine dining experience with a Filipino touch, offering carefully curated dishes made from high-quality, fresh ingredients.
                    </p>
                    <p class="text-base text-gray-600 mb-4 leading-relaxed">
                        Every meal is thoughtfully prepared, blending traditional Filipino flavors with modern culinary techniques to create a luxurious dining experience.
                    </p>
                    <p class="text-base text-gray-600 mb-8 leading-relaxed">
                        Whether for weddings, corporate events, or private celebrations, Every Event ensures a seamless and sophisticated dining experience, making every occasion truly memorable.
                    </p>
                    <div class="flex flex-wrap gap-4">
                        <a href="{{ path('app_menus') }}" class="btn-primary">
                            <i class="fas fa-utensils mr-2"></i>View Our Menu
                        </a>
                        <a href="{{ path('app_contact') }}" class="btn-secondary">
                            <i class="fas fa-envelope mr-2"></i>Get in Touch
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- ========== VALUES SECTION ========== -->
    <section class="py-24 bg-white relative overflow-hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16 scroll-animate">
                <span class="text-brand-gold font-semibold tracking-wider uppercase text-sm mb-2 block">What We Stand For</span>
                <h2 class="text-4xl md:text-5xl font-bold text-brand-charcoal mb-4">Our Values</h2>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    What drives us to deliver exceptional catering experiences
                </p>
                <div class="w-24 h-1 bg-gradient-to-r from-brand-gold to-brand-orange mx-auto mt-6 rounded-full"></div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="premium-card p-8 scroll-animate delay-100">
                    <div class="mb-6 w-16 h-16 bg-gradient-to-br from-brand-gold/20 to-brand-gold/10 rounded-2xl flex items-center justify-center">
                        <i class="fas fa-gem text-brand-gold text-2xl"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-brand-charcoal mb-3">Quality</h3>
                    <p class="text-gray-600 leading-relaxed">
                        We source only the finest, freshest ingredients to ensure every dish meets our highest standards of excellence.
                    </p>
                </div>
                
                <div class="premium-card p-8 scroll-animate delay-200">
                    <div class="mb-6 w-16 h-16 bg-gradient-to-br from-brand-gold/20 to-brand-gold/10 rounded-2xl flex items-center justify-center">
                        <i class="fas fa-palette text-brand-gold text-2xl"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-brand-charcoal mb-3">Customization</h3>
                    <p class="text-gray-600 leading-relaxed">
                        Every event is unique. We tailor our menus and services to match your vision and preferences perfectly.
                    </p>
                </div>
                
                <div class="premium-card p-8 scroll-animate delay-300">
                    <div class="mb-6 w-16 h-16 bg-gradient-to-br from-brand-gold/20 to-brand-gold/10 rounded-2xl flex items-center justify-center">
                        <i class="fas fa-concierge-bell text-brand-gold text-2xl"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-brand-charcoal mb-3">Exceptional Service</h3>
                    <p class="text-gray-600 leading-relaxed">
                        Our dedicated team ensures seamless execution and unforgettable moments for your special occasion.
                    </p>
                </div>
            </div>
        </div>
    </section>
    
    <!-- ========== MEET THE TEAM SECTION ========== -->
    <section class="py-24 bg-brand-cream-dark relative overflow-hidden">
        <!-- Decorative elements -->
        <div class="decoration-blob w-80 h-80 top-20 -left-40 opacity-20"></div>
        <div class="decoration-blob w-64 h-64 bottom-20 -right-32 opacity-15"></div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="text-center mb-16 scroll-animate">
                <span class="text-brand-gold font-semibold tracking-wider uppercase text-sm mb-2 block">The People Behind</span>
                <h2 class="text-4xl md:text-5xl font-bold text-brand-charcoal mb-4">Meet the Team</h2>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    Passionate professionals dedicated to creating extraordinary culinary experiences
                </p>
                <div class="w-24 h-1 bg-gradient-to-r from-brand-gold to-brand-orange mx-auto mt-6 rounded-full"></div>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
                
                <!-- Team Member 1: John Rio -->
                <div class="premium-card group scroll-animate delay-100">
                    <div class="relative h-72 overflow-hidden">
                        <img src="/images/meBitoy.jpg" alt="John Rio - Founder & Owner" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                        <div class="absolute inset-0 bg-gradient-to-t from-brand-charcoal/80 to-transparent"></div>
                        <div class="absolute bottom-4 left-4 right-4">
                            <span class="inline-block bg-brand-gold text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">
                                Founder & Owner
                            </span>
                        </div>
                    </div>
                    <div class="p-6 text-center">
                        <h3 class="text-xl font-bold text-brand-charcoal mb-2">John Rio</h3>
                        <p class="text-gray-600 text-sm leading-relaxed">
                            "Visionary behind the brand, dedicated to merging seamless logistics with premium culinary experiences."
                        </p>
                    </div>
                </div>
                
                <!-- Team Member 2: Deib Lohr Enrile -->
                <div class="premium-card group scroll-animate delay-200">
                    <div class="relative h-72 overflow-hidden">
                        <img src="/images/chefbitoy.png" alt="Deib Lohr Enrile - Executive Chef" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                        <div class="absolute inset-0 bg-gradient-to-t from-brand-charcoal/80 to-transparent"></div>
                        <div class="absolute bottom-4 left-4 right-4">
                            <span class="inline-block bg-brand-gold text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">
                                Executive Chef
                            </span>
                        </div>
                    </div>
                    <div class="p-6 text-center">
                        <h3 class="text-xl font-bold text-brand-charcoal mb-2">Deib Lohr Enrile</h3>
                        <p class="text-gray-600 text-sm leading-relaxed">
                            "Directs the kitchen team and crafts custom menus tailored to client preferences."
                        </p>
                    </div>
                </div>
                
                <!-- Team Member 3: Maxpein Del Valle -->
                <div class="premium-card group scroll-animate delay-300">
                    <div class="relative h-72 overflow-hidden">
                        <img src="/images/eventcoorbitoy.png" alt="Maxpein Del Valle - Event Coordinator" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                        <div class="absolute inset-0 bg-gradient-to-t from-brand-charcoal/80 to-transparent"></div>
                        <div class="absolute bottom-4 left-4 right-4">
                            <span class="inline-block bg-brand-gold text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">
                                Event Coordinator
                            </span>
                        </div>
                    </div>
                    <div class="p-6 text-center">
                        <h3 class="text-xl font-bold text-brand-charcoal mb-2">Maxpein Del Valle</h3>
                        <p class="text-gray-600 text-sm leading-relaxed">
                            "The primary point of contact for clients, ensuring every detail of the venue matches the vision."
                        </p>
                    </div>
                </div>
                
                <!-- Team Member 4: Manuel Duhay -->
                <div class="premium-card group scroll-animate delay-400">
                    <div class="relative h-72 overflow-hidden">
                        <img src="/images/bitoyopermanager.jpg" alt="Manuel Duhay - Operations Manager" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                        <div class="absolute inset-0 bg-gradient-to-t from-brand-charcoal/80 to-transparent"></div>
                        <div class="absolute bottom-4 left-4 right-4">
                            <span class="inline-block bg-brand-gold text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">
                                Operations Manager
                            </span>
                        </div>
                    </div>
                    <div class="p-6 text-center">
                        <h3 class="text-xl font-bold text-brand-charcoal mb-2">Manuel Duhay</h3>
                        <p class="text-gray-600 text-sm leading-relaxed">
                            "Manages the behind-the-scenes flow, from equipment transport to on-site staffing."
                        </p>
                    </div>
                </div>
                
            </div>
        </div>
    </section>
    
    <!-- ========== CTA SECTION ========== -->
    <section class="py-24 bg-brand-charcoal relative overflow-hidden">
        <div class="absolute inset-0">
            <div class="decoration-blob w-[500px] h-[500px] top-0 right-0 opacity-10"></div>
            <div class="decoration-blob w-[400px] h-[400px] bottom-0 left-0 opacity-10"></div>
        </div>
        
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10 scroll-animate">
            <span class="inline-block px-4 py-2 bg-brand-gold/20 text-brand-gold text-sm font-semibold rounded-full mb-6">
                Let's Work Together
            </span>
            <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
                Let's Create Something <span class="gold-gradient-text">Memorable</span>
            </h2>
            <p class="text-gray-300 text-lg mb-10 max-w-2xl mx-auto">
                Ready to experience Every Event's premium catering services? Our team is excited to bring your vision to life.
            </p>
            <a href="{{ path('app_contact') }}" class="btn-primary text-lg px-8 py-4">
                <i class="fas fa-calendar-check mr-2"></i>Contact Us Today
            </a>
        </div>
    </section>
{% endblock %}
