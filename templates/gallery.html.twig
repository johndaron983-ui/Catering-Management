{% extends "base.html.twig" %}

{% block title %}Gallery - Every Event | Premium Catering & Events{% endblock %}

{% block body %}
    <!-- ========== HERO SECTION ========== -->
    <section class="relative py-32 bg-brand-charcoal overflow-hidden">
        <div class="absolute inset-0">
            <div class="decoration-blob w-[600px] h-[600px] -top-48 -right-48 opacity-20"></div>
            <div class="decoration-blob w-[400px] h-[400px] bottom-0 left-0 opacity-15"></div>
        </div>
        
        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <span class="inline-block px-4 py-2 bg-brand-gold/20 text-brand-gold text-sm font-semibold rounded-full mb-4 scroll-animate">
                <i class="fas fa-images mr-2"></i>Visual Journey
            </span>
            <h1 class="text-5xl md:text-6xl font-bold text-white mb-6 scroll-animate">
                Our <span class="gold-gradient-text">Gallery</span>
            </h1>
            <p class="text-xl text-gray-300 max-w-2xl mx-auto scroll-animate delay-100">
                Stunning catering setups and dining experiences captured in moments
            </p>
        </div>
    </section>
    
    <!-- ========== GALLERY GRID ========== -->
    <section class="py-24 bg-brand-cream relative overflow-hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16 scroll-animate">
                <span class="text-brand-gold font-semibold tracking-wider uppercase text-sm mb-2 block">Portfolio</span>
                <h2 class="text-4xl md:text-5xl font-bold text-brand-charcoal mb-4">Event Highlights</h2>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    Browse through our collection of beautifully crafted events and culinary presentations
                </p>
                <div class="w-24 h-1 bg-gradient-to-r from-brand-gold to-brand-orange mx-auto mt-6 rounded-full"></div>
            </div>
            
            <!-- Masonry Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <!-- Gallery Item 1 - Large -->
                <div class="menu-item group cursor-pointer md:row-span-2 scroll-animate delay-100" data-lightbox="/images/wedding.jpg">
                    <img src="/images/wedding.jpg" alt="Wedding Reception" class="h-96 md:h-full">
                    <div class="menu-overlay">
                        <span class="text-brand-gold text-sm font-semibold mb-1">Wedding</span>
                        <h4 class="text-white text-xl font-bold">Wedding Reception</h4>
                        <p class="text-gray-300 text-sm">Elegant table arrangements</p>
                        <div class="mt-4 flex items-center gap-2 text-brand-gold">
                            <i class="fas fa-search-plus"></i>
                            <span class="text-sm">Click to enlarge</span>
                        </div>
                    </div>
                </div>
                
                <!-- Gallery Item 2 -->
                <div class="menu-item group cursor-pointer scroll-animate delay-200" data-lightbox="/images/lecheflan.jpg">
                    <img src="/images/lecheflan.jpg" alt="Dessert Display" class="h-64">
                    <div class="menu-overlay">
                        <span class="text-brand-gold text-sm font-semibold mb-1">Dessert</span>
                        <h4 class="text-white text-xl font-bold">Dessert Display</h4>
                        <p class="text-gray-300 text-sm">Sweet masterpieces</p>
                    </div>
                </div>
                
                <!-- Gallery Item 3 -->
                <div class="menu-item group cursor-pointer scroll-animate delay-300" data-lightbox="/images/appetizer.jpg">
                    <img src="/images/appetizer.jpg" alt="Appetizers" class="h-64">
                    <div class="menu-overlay">
                        <span class="text-brand-gold text-sm font-semibold mb-1">Appetizer</span>
                        <h4 class="text-white text-xl font-bold">Appetizers</h4>
                        <p class="text-gray-300 text-sm">Perfect starters</p>
                    </div>
                </div>
                
                <!-- Gallery Item 4 -->
                <div class="menu-item group cursor-pointer scroll-animate delay-100" data-lightbox="/images/casual.jpeg">
                    <img src="/images/casual.jpeg" alt="Main Course" class="h-64">
                    <div class="menu-overlay">
                        <span class="text-brand-gold text-sm font-semibold mb-1">Main Course</span>
                        <h4 class="text-white text-xl font-bold">Main Course</h4>
                        <p class="text-gray-300 text-sm">Signature dishes</p>
                    </div>
                </div>
                
                <!-- Gallery Item 5 -->
                <div class="menu-item group cursor-pointer scroll-animate delay-200" data-lightbox="/images/corporate.jpg">
                    <img src="/images/corporate.jpg" alt="Corporate Event" class="h-64">
                    <div class="menu-overlay">
                        <span class="text-brand-gold text-sm font-semibold mb-1">Corporate</span>
                        <h4 class="text-white text-xl font-bold">Corporate Event</h4>
                        <p class="text-gray-300 text-sm">Professional setup</p>
                    </div>
                </div>
                
                <!-- Gallery Item 6 -->
                <div class="menu-item group cursor-pointer scroll-animate delay-300" data-lightbox="/images/bday.jpg">
                    <img src="/images/bday.jpg" alt="Birthday Celebration" class="h-64">
                    <div class="menu-overlay">
                        <span class="text-brand-gold text-sm font-semibold mb-1">Celebration</span>
                        <h4 class="text-white text-xl font-bold">Birthday Party</h4>
                        <p class="text-gray-300 text-sm">Festive atmosphere</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- ========== TESTIMONIALS SECTION ========== -->
    <section class="py-24 bg-white relative overflow-hidden">
        <div class="decoration-blob w-64 h-64 top-10 -right-32 opacity-20"></div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="text-center mb-16 scroll-animate">
                <span class="text-brand-gold font-semibold tracking-wider uppercase text-sm mb-2 block">Testimonials</span>
                <h2 class="text-4xl md:text-5xl font-bold text-brand-charcoal mb-4">What Our Clients Say</h2>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    Hear from couples and event organizers who trusted Every Event with their special occasions
                </p>
                <div class="w-24 h-1 bg-gradient-to-r from-brand-gold to-brand-orange mx-auto mt-6 rounded-full"></div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Testimonial 1 -->
                <div class="testimonial-card scroll-animate delay-100">
                    <div class="flex text-brand-gold mb-4">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                    </div>
                    <p class="text-gray-600 mb-6 leading-relaxed relative z-10">
                        "Every Event made our wedding day absolutely perfect. The food was exquisite, the presentation was elegant, and the service was impeccable. We couldn't have asked for more!"
                    </p>
                    <div class="border-t border-gray-200 pt-4">
                        <p class="font-semibold text-brand-charcoal">Maria & Juan Lopez</p>
                        <p class="text-sm text-gray-500">Wedding - June 2025</p>
                    </div>
                </div>
                
                <!-- Testimonial 2 -->
                <div class="testimonial-card scroll-animate delay-200">
                    <div class="flex text-brand-gold mb-4">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                    </div>
                    <p class="text-gray-600 mb-6 leading-relaxed relative z-10">
                        "The corporate catering for our annual gala was outstanding. Professional staff, delicious food, and seamless coordination. We'll definitely be booking with them again!"
                    </p>
                    <div class="border-t border-gray-200 pt-4">
                        <p class="font-semibold text-brand-charcoal">Robert Chen</p>
                        <p class="text-sm text-gray-500">Corporate Event - April 2025</p>
                    </div>
                </div>
                
                <!-- Testimonial 3 -->
                <div class="testimonial-card scroll-animate delay-300">
                    <div class="flex text-brand-gold mb-4">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                    </div>
                    <p class="text-gray-600 mb-6 leading-relaxed relative z-10">
                        "Every Event transformed our intimate birthday celebration into a memorable culinary experience. The customized menu was creative, and every detail was perfect!"
                    </p>
                    <div class="border-t border-gray-200 pt-4">
                        <p class="font-semibold text-brand-charcoal">Andrea Santos</p>
                        <p class="text-sm text-gray-500">Birthday Party - March 2025</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- ========== CTA SECTION ========== -->
    <section class="py-24 bg-brand-charcoal relative overflow-hidden">
        <div class="absolute inset-0">
            <div class="decoration-blob w-[500px] h-[500px] top-0 right-0 opacity-10"></div>
            <div class="decoration-blob w-[400px] h-[400px] bottom-0 left-0 opacity-10"></div>
        </div>
        
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10 scroll-animate">
            <span class="inline-block px-4 py-2 bg-brand-gold/20 text-brand-gold text-sm font-semibold rounded-full mb-6">
                Start Your Journey
            </span>
            <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
                Create Your Own <span class="gold-gradient-text">Memorable Event</span>
            </h2>
            <p class="text-gray-300 text-lg mb-10 max-w-2xl mx-auto">
                Let Every Event be part of your special occasion. Contact us today to get started!
            </p>
            <a href="{{ path('app_contact') }}" class="btn-primary text-lg px-8 py-4">
                <i class="fas fa-calendar-check mr-2"></i>Book Your Event
            </a>
        </div>
    </section>
{% endblock %}
