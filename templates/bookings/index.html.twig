{% extends 'admin/layout.html.twig' %}

{% block title %}Bookings{% endblock %}

{% block admin_body %}
<div class="max-w-7xl mx-auto">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-xl font-semibold text-gray-800">Bookings</h1>
        <a href="{{ path('app_bookings_new') }}" class="inline-flex items-center rounded-md bg-[#235A2F] px-4 py-2 text-white hover:opacity-90">New Booking</a>
    </div>

    <!-- SEARCH AND FILTER -->
    <div class="bg-white rounded-lg shadow-sm p-6 mb-6 border border-gray-200">
        <div class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                <!-- Customer Search -->
                <div>
                    <label for="search-customer" class="block text-sm font-medium text-gray-700">Customer Name</label>
                    <input 
                        type="text" 
                        id="search-customer" 
                        placeholder="Search customer..."
                        class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#235A2F] focus:ring-[#235A2F]"
                    >
                </div>

                <!-- Service Filter -->
                <div>
                    <label for="filter-service" class="block text-sm font-medium text-gray-700">Service</label>
                    <select id="filter-service" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#235A2F] focus:ring-[#235A2F]">
                        <option value="">All Services</option>
                        {% for service in services %}
                            <option value="{{ service.name }}">{{ service.name }}</option>
                        {% endfor %}
                    </select>
                </div>

                <!-- Status Filter -->
                <div>
                    <label for="filter-status" class="block text-sm font-medium text-gray-700">Status</label>
                    <select id="filter-status" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#235A2F] focus:ring-[#235A2F]">
                        <option value="">All Status</option>
                        <option value="pending">Pending</option>
                        <option value="confirmed">Confirmed</option>
                        <option value="completed">Completed</option>
                        <option value="cancelled">Cancelled</option>
                    </select>
                </div>
            </div>

            <div class="flex gap-2">
                <button id="clear-filters" class="inline-flex items-center rounded-md bg-gray-400 px-4 py-2 text-white hover:opacity-90">
                    Clear Filters
                </button>
            </div>
        </div>
    </div>

    {# Track the max booking id already rendered (prevents polling from duplicating). #}
    {% set max_booking_id = 0 %}
    {% for booking in bookings %}
        {% if booking.id > max_booking_id %}
            {% set max_booking_id = booking.id %}
        {% endif %}
    {% endfor %}

    <div class="mt-4 overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
        <div class="overflow-x-auto">
            <table id="bookings-table" class="min-w-full table-auto text-sm">
                <thead class="bg-gray-50 text-gray-600">
                    <tr>
                        <th class="px-4 py-3 text-left font-medium">Image</th>
                        <th class="px-4 py-3 text-left font-medium">Service</th>
                        <th class="px-4 py-3 text-left font-medium">Customer</th>
                        <th class="px-4 py-3 text-left font-medium">Event Date</th>
                        <th class="px-4 py-3 text-left font-medium">Status</th>
                        <th class="px-4 py-3 text-left font-medium">Guests</th>
                        <th class="px-4 py-3 text-left font-medium">Total</th>
                        <th class="px-4 py-3 text-left font-medium">Created By</th>
                        <th class="px-4 py-3 text-left font-medium">Actions</th>
                    </tr>
                </thead>
                <tbody id="bookings-tbody" class="divide-y divide-gray-100 text-gray-800">
                {% for booking in bookings %}
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3">
                            {% if booking.service and booking.service.image %}
                                <img src="{{ asset('image/' ~ booking.service.image) }}" alt="{{ booking.service.name }}" class="h-12 w-12 object-cover rounded-md">
                            {% else %}
                                <div class="h-12 w-12 bg-gray-200 rounded-md flex items-center justify-center">
                                    <span class="text-gray-400 text-xs">No image</span>
                                </div>
                            {% endif %}
                        </td>
                        <td class="px-4 py-3">{{ booking.service ? booking.service.name : '' }}</td>
                        <td class="px-4 py-3">{{ booking.customerName }}</td>
                        <td class="px-4 py-3">{{ booking.eventDate ? booking.eventDate|date('Y-m-d H:i') : '' }}</td>
                        <td class="px-4 py-3 capitalize">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                                {% if booking.status == 'pending' %}
                                    bg-yellow-100 text-yellow-800
                                {% elseif booking.status == 'confirmed' %}
                                    bg-blue-100 text-blue-800
                                {% elseif booking.status == 'completed' %}
                                    bg-green-100 text-green-800
                                {% elseif booking.status == 'cancelled' %}
                                    bg-red-100 text-red-800
                                {% else %}
                                    bg-gray-100 text-gray-800
                                {% endif %}
                            ">{{ booking.status }}</span>
                        </td>
                        <td class="px-4 py-3">{{ booking.guestCount }}</td>
                        <td class="px-4 py-3">₱{{ booking.totalPrice|number_format(2, '.', ',') }}</td>
                        <td class="px-4 py-3">{{ booking.createdBy ? booking.createdBy.username : '-' }}</td>
                        <td class="px-4 py-3 space-x-2">
                            <a href="{{ path('app_bookings_show', {'id': booking.id}) }}" class="inline-flex items-center rounded-md bg-blue-600 px-3 py-1.5 text-white hover:opacity-90">Show</a>
                            <a href="{{ path('app_bookings_edit', {'id': booking.id}) }}" class="inline-flex items-center rounded-md bg-emerald-600 px-3 py-1.5 text-white hover:opacity-90">Edit</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="9" class="px-4 py-6 text-center text-gray-500">No bookings found</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% block scripts %}
{{ parent() }}
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/jquery.dataTables.min.css">
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>

<script>
function formatPeso(value) {
    try {
        return '₱' + Number(value).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    } catch (e) {
        return '₱' + value;
    }
}

function statusBadge(status) {
    const s = (status || '').toLowerCase();
    const base = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium';
    if (s === 'pending') return `<span class="${base} bg-yellow-100 text-yellow-800">pending</span>`;
    if (s === 'confirmed') return `<span class="${base} bg-blue-100 text-blue-800">confirmed</span>`;
    if (s === 'completed') return `<span class="${base} bg-green-100 text-green-800">completed</span>`;
    if (s === 'cancelled') return `<span class="${base} bg-red-100 text-red-800">cancelled</span>`;
    return `<span class="${base} bg-gray-100 text-gray-800">${s || '-'}</span>`;
}

function imageCell(serviceImage, serviceName) {
    if (serviceImage) {
        return `<img src="${serviceImage}" alt="${serviceName || ''}" class="h-12 w-12 object-cover rounded-md">`;
    }
    return `<div class="h-12 w-12 bg-gray-200 rounded-md flex items-center justify-center"><span class="text-gray-400 text-xs">No image</span></div>`;
}

function initializeBookingsTable() {
    // Destroy existing DataTable instance if it exists
    if ($.fn.DataTable.isDataTable('#bookings-table')) {
        $('#bookings-table').DataTable().destroy();
    }

    const table = $('#bookings-table').DataTable({
        responsive: true,
        pageLength: 25,
        lengthChange: true,
        searching: true,
        ordering: true,
        info: true,
        paging: true,
        dom: '<"top"lf>rt<"bottom"ip>',
        columnDefs: [
            { orderable: false, targets: 0 },  // Image column
            { orderable: false, targets: 8 }   // Actions column
        ]
    });

    // Column indices (0-based)
    const COL_SERVICE = 1;
    const COL_CUSTOMER = 2;
    const COL_STATUS = 4;

    // Filter by Service dropdown
    $('#filter-service').off('change').on('change', function() {
        table.column(COL_SERVICE).search(this.value).draw();
    });

    // Filter by Status dropdown
    $('#filter-status').off('change').on('change', function() {
        table.column(COL_STATUS).search(this.value).draw();
    });

    // Search by Customer Name with debouncing
    let searchTimeout;
    $('#search-customer').off('keyup').on('keyup', function() {
        clearTimeout(searchTimeout);
        const searchValue = this.value;
        searchTimeout = setTimeout(() => {
            table.column(COL_CUSTOMER).search(searchValue).draw();
        }, 300);
    });

    // Clear all filters
    $('#clear-filters').off('click').on('click', function(e) {
        e.preventDefault();
        
        $('#filter-service').val('').trigger('change');
        $('#filter-status').val('').trigger('change');
        $('#search-customer').val('');
        
        table.search('').columns().search('').draw();
    });
}

function injectBookingIntoTable(booking) {
    if (!booking || !booking.id) return;
    // Strong guard against double-inserts (polling + SSE, turbo renders, etc.)
    if (!window.__adminBookingIds) window.__adminBookingIds = new Set();
    if (window.__adminBookingIds.has(String(booking.id))) return;

    if (!$.fn.DataTable.isDataTable('#bookings-table')) {
        // If DataTable isn't ready yet, try again shortly.
        setTimeout(() => injectBookingIntoTable(booking), 150);
        return;
    }

    const table = $('#bookings-table').DataTable();

    // Prevent duplicates if multiple tabs/publishes happen
    const existing = document.querySelector(`tr[data-booking-id="${booking.id}"]`);
    if (existing) return;

    const showUrl = `/bookings/${booking.id}`;
    const editUrl = `/bookings/${booking.id}/edit`;

    const row = [
        imageCell(booking.service_image, booking.service_name),
        booking.service_name || '',
        booking.customer_name || '',
        booking.event_date || '',
        statusBadge(booking.status),
        booking.guest_count != null ? String(booking.guest_count) : '',
        formatPeso(booking.total_price || 0),
        booking.created_by || '-',
        `<a href="${showUrl}" class="inline-flex items-center rounded-md bg-blue-600 px-3 py-1.5 text-white hover:opacity-90">Show</a>
         <a href="${editUrl}" class="inline-flex items-center rounded-md bg-emerald-600 px-3 py-1.5 text-white hover:opacity-90">Edit</a>`
    ];

    const node = table.row.add(row).draw(false).node();
    node.classList.add('hover:bg-gray-50');
    node.setAttribute('data-booking-id', booking.id);
    window.__adminBookingIds.add(String(booking.id));

    // Move the newly-added row to the top visually
    const tbody = document.querySelector('#bookings-table tbody');
    if (tbody && node && node.parentNode === tbody) {
        tbody.insertBefore(node, tbody.firstChild);
    }
}

// Initialize on page load and Turbo navigation
document.addEventListener('DOMContentLoaded', initializeBookingsTable);
document.addEventListener('turbo:load', initializeBookingsTable);
document.addEventListener('turbo:render', initializeBookingsTable);

// Listen for Mercure admin events dispatched from base.html.twig
window.addEventListener('admin:booking_created', function(e) {
    const booking = e && e.detail ? e.detail : null;
    injectBookingIntoTable(booking);
});

// Polling fallback (Railway free plan friendly): inject new bookings without Mercure.
(function startBookingsPolling() {
    let afterId = Number({{ max_booking_id }}) || 0;
    let isRunning = false;

    async function tick() {
        if (isRunning) return;
        isRunning = true;
        try {
            const res = await fetch(`/admin/realtime/snapshot?afterId=${afterId}`, {
                headers: { 'Accept': 'application/json' }
            });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            const data = await res.json();
            if (data && data.success) {
                afterId = Math.max(afterId, Number(data.latestId || afterId));
                const list = Array.isArray(data.newBookings) ? data.newBookings : [];
                // API returns DESC by id; inject each so the newest ends up on top.
                for (const b of list) {
                    injectBookingIntoTable(b);
                }
            }
        } catch (e) {
            // silent: retry next tick
        } finally {
            isRunning = false;
            setTimeout(tick, 4000);
        }
    }

    setTimeout(tick, 1500);
})();
</script>
{% endblock %}
{% endblock %}


