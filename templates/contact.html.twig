{% extends "base.html.twig" %}

{% block title %}Contact Us - Every Event | Premium Catering & Events{% endblock %}

{% block body %}
    <!-- ========== HERO SECTION ========== -->
    <section class="relative py-32 bg-brand-charcoal overflow-hidden">
        <div class="absolute inset-0">
            <div class="decoration-blob w-[600px] h-[600px] -top-48 -right-48 opacity-20"></div>
            <div class="decoration-blob w-[400px] h-[400px] bottom-0 left-0 opacity-15"></div>
        </div>
        
        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <span class="inline-block px-4 py-2 bg-brand-gold/20 text-brand-gold text-sm font-semibold rounded-full mb-4 scroll-animate">
                <i class="fas fa-envelope mr-2"></i>Get In Touch
            </span>
            <h1 class="text-5xl md:text-6xl font-bold text-white mb-6 scroll-animate">
                Contact <span class="gold-gradient-text">Us</span>
            </h1>
            <p class="text-xl text-gray-300 max-w-2xl mx-auto scroll-animate delay-100">
                Have questions or inquiries? Fill out the form below and we'll get back to you as soon as possible.
            </p>
        </div>
    </section>
    
    <!-- ========== CONTACT SECTION ========== -->
    <section class="py-24 bg-brand-cream relative overflow-hidden">
        <div class="decoration-blob w-96 h-96 -top-48 -right-48 opacity-20"></div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
                <!-- Left Content -->
                <div class="scroll-animate-left">
                    <span class="text-brand-gold font-semibold tracking-wider uppercase text-sm mb-2 block">Let's Connect</span>
                    <h2 class="text-4xl md:text-5xl font-bold text-brand-charcoal mb-6 leading-tight">
                        Let's Create<br>Something Special
                    </h2>
                    <p class="text-base text-gray-600 mb-4 leading-relaxed">
                        We offer catering services and accept online booking. Through your comfort, we're passionate about bringing the vibrant flavors of Filipino cuisine right to your doorstep.
                    </p>
                    <p class="text-base text-gray-600 mb-8 leading-relaxed">
                        Our dedicated team is ready to help you plan the perfect event. Contact us today to discuss your vision and get a customized quote.
                    </p>
                    
                    <!-- Contact Info Cards -->
                    <div class="space-y-4 mb-8">
                        <div class="premium-card p-6 flex items-start gap-4 hover:shadow-lg transition-all duration-300">
                            <div class="w-12 h-12 bg-brand-gold/10 rounded-xl flex items-center justify-center flex-shrink-0">
                                <i class="fas fa-phone text-brand-gold text-lg"></i>
                            </div>
                            <div>
                                <p class="font-semibold text-brand-charcoal mb-1">Phone</p>
                                <p class="text-gray-600 text-sm">+1 (555) 123-4567</p>
                                <p class="text-gray-600 text-sm">WhatsApp: +1 (555) 987-6543</p>
                            </div>
                        </div>
                        
                        <div class="premium-card p-6 flex items-start gap-4 hover:shadow-lg transition-all duration-300">
                            <div class="w-12 h-12 bg-brand-gold/10 rounded-xl flex items-center justify-center flex-shrink-0">
                                <i class="fas fa-envelope text-brand-gold text-lg"></i>
                            </div>
                            <div>
                                <p class="font-semibold text-brand-charcoal mb-1">Email</p>
                                <p class="text-gray-600 text-sm">info@everyevent.com</p>
                                <p class="text-gray-600 text-sm">catering@everyevent.com</p>
                            </div>
                        </div>
                        
                        <div class="premium-card p-6 flex items-start gap-4 hover:shadow-lg transition-all duration-300">
                            <div class="w-12 h-12 bg-brand-gold/10 rounded-xl flex items-center justify-center flex-shrink-0">
                                <i class="fas fa-map-marker-alt text-brand-gold text-lg"></i>
                            </div>
                            <div>
                                <p class="font-semibold text-brand-charcoal mb-1">Location</p>
                                <p class="text-gray-600 text-sm">Dumaguete City, Philippines</p>
                            </div>
                        </div>
                        
                        <div class="premium-card p-6 flex items-start gap-4 hover:shadow-lg transition-all duration-300">
                            <div class="w-12 h-12 bg-brand-gold/10 rounded-xl flex items-center justify-center flex-shrink-0">
                                <i class="fas fa-clock text-brand-gold text-lg"></i>
                            </div>
                            <div>
                                <p class="font-semibold text-brand-charcoal mb-1">Business Hours</p>
                                <p class="text-gray-600 text-sm">Mon - Sat: 8:00 AM - 8:00 PM</p>
                                <p class="text-gray-600 text-sm">Sunday: Closed</p>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Social Links -->
                    <div class="flex gap-4">
                        <a href="https://facebook.com" target="_blank" class="w-12 h-12 bg-brand-gold/10 rounded-xl flex items-center justify-center hover:bg-brand-gold hover:text-white transition-all text-brand-gold">
                            <i class="fab fa-facebook-f"></i>
                        </a>
                        <a href="https://instagram.com" target="_blank" class="w-12 h-12 bg-brand-gold/10 rounded-xl flex items-center justify-center hover:bg-brand-gold hover:text-white transition-all text-brand-gold">
                            <i class="fab fa-instagram"></i>
                        </a>
                        <a href="https://wa.me/15551234567" target="_blank" class="w-12 h-12 bg-brand-gold/10 rounded-xl flex items-center justify-center hover:bg-brand-gold hover:text-white transition-all text-brand-gold">
                            <i class="fab fa-whatsapp"></i>
                        </a>
                    </div>
                </div>
                
                <!-- Right Side - Google Form -->
                <div class="scroll-animate-right">
                    <!-- Google Form Card -->
                    <div id="formCard" class="premium-card p-8 rounded-2xl shadow-xl bg-white">
                        <div class="text-center mb-6">
                            <div class="w-16 h-16 bg-brand-gold/10 rounded-full flex items-center justify-center mx-auto mb-4">
                                <i class="fas fa-paper-plane text-brand-gold text-2xl"></i>
                            </div>
                            <h3 class="text-2xl font-bold text-brand-charcoal mb-2">Contact Us</h3>
                            <p class="text-gray-600 text-sm">Have questions or inquiries? Fill out the form below and we'll get back to you as soon as possible.</p>
                        </div>
                        
                        <!-- Loading Indicator -->
                        <div id="loadingIndicator" class="hidden py-12 text-center">
                            <div class="inline-block animate-spin rounded-full h-12 w-12 border-4 border-brand-gold border-t-transparent"></div>
                            <p class="mt-4 text-gray-600">Submitting your message...</p>
                        </div>
                        
                        <!-- Google Form iframe -->
                        <div id="formContainer" class="relative">
                            <iframe 
                                id="googleForm"
                                src="https://docs.google.com/forms/d/e/1FAIpQLSeyMPtumEEeozCWdgHrFv1jCn15HtYFxnTDNOQIbeQ-uMiWOQ/viewform?embedded=true" 
                                width="100%" 
                                height="600" 
                                frameborder="0" 
                                marginheight="0" 
                                marginwidth="0"
                                class="rounded-xl"
                                style="min-height: 600px;"
                            >Loading…</iframe>
                        </div>
                    </div>
                    
                    <!-- Success Message (Hidden by default) -->
                    <div id="successCard" class="hidden premium-card p-8 rounded-2xl shadow-xl bg-white text-center animate-fade-in-up">
                        <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6 animate-zoom-in">
                            <i class="fas fa-check-circle text-green-500 text-4xl"></i>
                        </div>
                        <h3 class="text-3xl font-bold text-brand-charcoal mb-4">Message Sent!</h3>
                        <div class="bg-green-50 border border-green-200 rounded-xl p-4 mb-6">
                            <p class="text-green-800 text-lg flex items-center justify-center gap-2">
                                <i class="fas fa-check"></i>
                                Your message has been successfully sent!
                            </p>
                        </div>
                        <p class="text-gray-600 mb-6">
                            Thank you for reaching out to us. We've received your inquiry and will get back to you within 24-48 hours.
                        </p>
                        <div class="flex flex-col sm:flex-row gap-4 justify-center">
                            <button 
                                onclick="resetForm()" 
                                class="bg-brand-gold hover:bg-brand-gold-dark text-white font-semibold py-3 px-6 rounded-xl transition-all duration-300 shadow-md hover:shadow-lg flex items-center justify-center gap-2"
                            >
                                <i class="fas fa-paper-plane"></i>
                                Send Another Message
                            </button>
                            <a 
                                href="{{ path('app_home') }}" 
                                class="bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-3 px-6 rounded-xl transition-all duration-300 flex items-center justify-center gap-2"
                            >
                                <i class="fas fa-home"></i>
                                Back to Home
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- ========== MAP SECTION ========== -->
    <section class="py-24 bg-white relative overflow-hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12 scroll-animate">
                <span class="text-brand-gold font-semibold tracking-wider uppercase text-sm mb-2 block">Visit Us</span>
                <h2 class="text-4xl md:text-5xl font-bold text-brand-charcoal mb-4">Find Us</h2>
                <p class="text-lg text-gray-600">Visit our location in Dumaguete City</p>
                <div class="w-24 h-1 bg-gradient-to-r from-brand-gold to-brand-orange mx-auto mt-6 rounded-full"></div>
            </div>
            
            <div class="rounded-2xl overflow-hidden shadow-2xl scroll-animate h-[450px]">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3926.891421345678!2d123.3114!3d9.3031!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x33addb571c50a5b5%3A0x0!2sDumaguete%20City!5e0!3m2!1sen!2sph!4v1234567890" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
        </div>
    </section>
{% endblock %}

{% block scripts %}
<script>
    /**
     * Show success message after form submission
     * This can be triggered by:
     * 1. The demo button (for testing)
     * 2. Detecting iframe URL change (when Google Form redirects after submission)
     * 3. Using Google Forms' redirect URL feature
     */
    function showSuccessMessage() {
        // Hide form card with fade out
        const formCard = document.getElementById('formCard');
        formCard.style.opacity = '0';
        formCard.style.transform = 'translateY(-20px)';
        formCard.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
        
        setTimeout(() => {
            formCard.classList.add('hidden');
            
            // Show success card with animation
            const successCard = document.getElementById('successCard');
            successCard.classList.remove('hidden');
            
            // Scroll to success message
            successCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }, 400);
    }
    
    /**
     * Reset the form to show it again
     */
    function resetForm() {
        const successCard = document.getElementById('successCard');
        const formCard = document.getElementById('formCard');
        const iframe = document.getElementById('googleForm');
        
        // Hide success card
        successCard.classList.add('hidden');
        
        // Reset form card styles and show it
        formCard.classList.remove('hidden');
        formCard.style.opacity = '1';
        formCard.style.transform = 'translateY(0)';
        
        // Reload iframe to clear form (if using real Google Form)
        if (iframe && iframe.src && !iframe.src.includes('YOUR_FORM_ID')) {
            const currentSrc = iframe.src;
            iframe.src = '';
            setTimeout(() => {
                iframe.src = currentSrc;
            }, 100);
        }
    }
    
    /**
     * Monitor iframe for URL changes (submission detection)
     * Note: Cross-origin restrictions may limit this functionality
     */
    function monitorFormSubmission() {
        const iframe = document.getElementById('googleForm');
        
        if (iframe && !iframe.src.includes('YOUR_FORM_ID')) {
            iframe.addEventListener('load', function() {
                // This will fire when the form loads and when it redirects
                // We can use this to detect successful submission
                try {
                    // Attempt to check if form was submitted by looking at URL
                    // This may not work due to cross-origin restrictions
                    console.log('Form iframe loaded/reloaded');
                } catch (e) {
                    // Cross-origin restriction - this is expected
                }
            });
        }
    }
    
    // Initialize form monitoring when page loads
    document.addEventListener('DOMContentLoaded', function() {
        monitorFormSubmission();
        
        // Check if there's a submission parameter in URL (for Google Forms redirect method)
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('submitted') === 'true') {
            showSuccessMessage();
        }
    });
    
    /**
     * Alternative: Use a proxy page approach
     * If you set up a custom Google Form confirmation page that redirects back
     * to this page with ?submitted=true, the success message will show automatically.
     */
</script>
{% endblock %}
